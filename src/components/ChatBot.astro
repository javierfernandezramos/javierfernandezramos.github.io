---
// ChatBot.astro - Asistente de IA para JaviPhoto usando Google Gemini
import { contactInfo } from '../data/config';
---

<div class="chatbot-wrapper" data-nosnippet>
    <!-- Botón de WhatsApp estilo notificación (Arriba a la Izquierda del botón de la IA) -->
    <a href={contactInfo.whatsappUrl} class="whatsapp-float-badge" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>

    <!-- Botón flotante (Abajo a la Derecha) -->
    <button id="chatbot-toggle" class="chatbot-toggle-btn" aria-label="Abrir asistente de IA">
        <i class="fas fa-comment-dots"></i>
    </button>

    <!-- Ventana de Chat -->
    <div id="chatbot-window" class="chatbot-window">
        <!-- Cabecera -->
        <div class="chatbot-header">
            <div class="header-info">
                <div class="bot-avatar">
                    <i class="fas fa-robot"></i>
                </div>
                <div>
                    <h4>Asistente JaviPhoto</h4>
                    <span class="status-indicator">En línea</span>
                </div>
            </div>
            <button id="chatbot-close" class="close-btn" aria-label="Cerrar chat">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <!-- Historial de Mensajes -->
        <div id="chatbot-messages" class="chatbot-messages">
            <!-- Mensaje de bienvenida inicial -->
            <div class="message-wrapper bot-wrapper">
                <span class="message-sender">Asistente</span>
                <div class="message bot-message">
                    <p>¡Hola! Soy el asistente virtual de JaviPhoto. Puedes hablar directamente con Javi o tambíen te puedo guiar sobre precios, packs de fotos o indicarte cómo reservar. ¿Qué te gustaría saber hoy?</p>
                </div>
            </div>
            <!-- Sugerencias iniciales -->
            <div class="suggestion-chips-container">
                <button class="suggestion-chip" data-question="¿Cuáles son tus packs y precios?">Ver packs y precios</button>
                <button class="suggestion-chip" data-question="¿Cómo funciona la reserva?">¿Cómo reservo?</button>
                <button class="suggestion-chip" data-question="¿Entregan las fotos editadas?">Entrega de fotos</button>
            </div>
        </div>

        <!-- Indicador de Escribiendo... -->
        <div id="chatbot-typing" class="chatbot-typing hidden">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <!-- Formulario de Entrada -->
        <form id="chatbot-input-form" class="chatbot-input-form">
            <input 
                type="text" 
                id="chatbot-input-field" 
                placeholder="Escribe tu mensaje..." 
                autocomplete="off" 
                maxlength="200"
                required 
            />
            <button type="submit" id="chatbot-send-btn" aria-label="Enviar mensaje">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

<style>
    /* Contenedor principal flotante */
    .chatbot-wrapper {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: 'Outfit', sans-serif;
    }

    /* Botón de WhatsApp estilo notificación (Arriba a la Izquierda del botón de la IA) */
    .whatsapp-float-badge {
        position: absolute;
        top: -6px;
        left: -6px;
        width: 26px;
        height: 26px;
        background-color: #25d366;
        color: #fff;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 0.85rem;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.4);
        z-index: 10002;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 2px solid var(--color-secondary, #0a0a0a);
        text-decoration: none;
        outline: none;
        -webkit-tap-highlight-color: transparent;
    }

    .whatsapp-float-badge:hover {
        transform: scale(1.2) rotate(15deg);
        background-color: #20ba5a;
        box-shadow: 0 4px 15px rgba(37, 211, 102, 0.6);
    }

    /* Botón flotante */
    .chatbot-toggle-btn {
        width: 55px;
        height: 55px;
        background-color: var(--color-secondary, #0a0a0a);
        border: 2px solid var(--color-gold, #c5a059);
        color: var(--color-gold, #c5a059);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.5rem;
        cursor: pointer;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.4);
        position: relative;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        outline: none;
        -webkit-tap-highlight-color: transparent;
    }

    .chatbot-toggle-btn:focus,
    .chatbot-toggle-btn:active,
    .whatsapp-float-badge:focus,
    .whatsapp-float-badge:active {
        outline: none;
        box-shadow: none;
    }

    .chatbot-toggle-btn:hover {
        transform: scale(1.08);
        background-color: var(--color-gold, #c5a059);
        color: var(--color-secondary, #0a0a0a);
        box-shadow: 0 8px 30px rgba(197, 160, 89, 0.4);
    }

    /* Ventana de Chat */
    .chatbot-window {
        position: absolute;
        bottom: 75px;
        right: 0;
        width: 390px;
        height: 550px;
        background: rgba(10, 10, 10, 0.96);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(197, 160, 89, 0.25);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        opacity: 0;
        visibility: hidden;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 10000;
    }

    .chatbot-window.active {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }

    /* Cabecera */
    .chatbot-header {
        background: rgba(197, 160, 89, 0.08);
        border-bottom: 1px solid rgba(197, 160, 89, 0.15);
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .bot-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(197, 160, 89, 0.15);
        color: var(--color-gold, #c5a059);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1.1rem;
        border: 1px solid rgba(197, 160, 89, 0.3);
    }

    .header-info h4 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
    }

    .status-indicator {
        font-size: 0.75rem;
        color: #25d366;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .status-indicator::before {
        content: '';
        display: inline-block;
        width: 6px;
        height: 6px;
        background-color: #25d366;
        border-radius: 50%;
    }

    .close-btn {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.1rem;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .close-btn:hover {
        color: var(--color-gold, #c5a059);
    }

    /* Historial de Mensajes */
    .chatbot-messages {
        flex: 1;
        padding: 1.25rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        scrollbar-width: thin;
        scrollbar-color: rgba(197, 160, 89, 0.2) transparent;
    }

    .chatbot-messages::-webkit-scrollbar {
        width: 4px;
    }

    .chatbot-messages::-webkit-scrollbar-thumb {
        background: rgba(197, 160, 89, 0.2);
        border-radius: 4px;
    }

    .chatbot-messages :global(.message-wrapper) {
        display: flex;
        flex-direction: column;
        max-width: 82%;
        gap: 3px;
    }

    .chatbot-messages :global(.message-wrapper.bot-wrapper) {
        align-self: flex-start;
    }

    .chatbot-messages :global(.message-wrapper.user-wrapper) {
        align-self: flex-end;
    }

    .chatbot-messages :global(.message-sender) {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 1px;
        font-weight: 700;
    }

    .chatbot-messages :global(.bot-wrapper .message-sender) {
        color: var(--color-gold, #c5a059);
        align-self: flex-start;
        margin-left: 4px;
    }

    .chatbot-messages :global(.user-wrapper .message-sender) {
        color: rgba(255, 255, 255, 0.45);
        align-self: flex-end;
        margin-right: 4px;
    }

    .chatbot-messages :global(.message) {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        font-size: 0.88rem;
        line-height: 1.5;
        word-wrap: break-word;
        box-sizing: border-box;
    }

    .chatbot-messages :global(.message p) {
        margin: 0;
    }

    .chatbot-messages :global(.message ul) {
        margin: 0.5rem 0 0 1rem;
        padding: 0;
    }

    .chatbot-messages :global(.message li) {
        margin-bottom: 0.25rem;
    }

    .chatbot-messages :global(.bot-message) {
        background: #181818;
        border: 1px solid rgba(197, 160, 89, 0.25);
        color: #ffffff;
        border-bottom-left-radius: 2px;
    }

    .chatbot-messages :global(.user-message) {
        background: var(--color-gold, #c5a059);
        color: var(--color-secondary, #0a0a0a);
        font-weight: 500;
        border-bottom-right-radius: 2px;
        border: none;
    }

    /* Sugerencias (Chips) */
    .suggestion-chips-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 5px;
        align-self: flex-start;
    }

    .suggestion-chip {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(197, 160, 89, 0.3);
        color: var(--color-gold, #c5a059);
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-size: 0.78rem;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: 'Outfit', sans-serif;
    }

    .suggestion-chip:hover {
        background: rgba(197, 160, 89, 0.1);
        border-color: var(--color-gold, #c5a059);
        transform: translateY(-1px);
    }

    /* Animación Escribiendo */
    .chatbot-typing {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 0.75rem 1.25rem;
        align-self: flex-start;
    }

    .chatbot-typing.hidden {
        display: none;
    }

    .chatbot-typing span {
        width: 6px;
        height: 6px;
        background-color: var(--color-gold, #c5a059);
        border-radius: 50%;
        display: inline-block;
        animation: chatbot-bounce 1.4s infinite ease-in-out both;
        opacity: 0.6;
    }

    .chatbot-typing span:nth-child(1) {
        animation-delay: -0.32s;
    }

    .chatbot-typing span:nth-child(2) {
        animation-delay: -0.16s;
    }

    @keyframes chatbot-bounce {
        0%, 80%, 100% { 
            transform: scale(0);
        } 40% { 
            transform: scale(1.0);
        }
    }

    /* Formulario de Entrada */
    .chatbot-input-form {
        border-top: 1px solid rgba(197, 160, 89, 0.15);
        padding: 0.75rem 1rem;
        display: flex;
        gap: 10px;
        align-items: center;
        background: rgba(5, 5, 5, 0.5);
    }

    .chatbot-input-form input {
        flex: 1;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        padding: 0.6rem 1.2rem;
        color: #fff;
        font-size: 0.85rem;
        outline: none;
        transition: border-color 0.3s ease;
        font-family: 'Outfit', sans-serif;
    }

    .chatbot-input-form input:focus {
        border-color: var(--color-gold, #c5a059);
    }

    .chatbot-input-form button {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--color-gold, #c5a059);
        color: var(--color-secondary, #0a0a0a);
        border: none;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

    .chatbot-input-form button:hover {
        transform: scale(1.05);
        filter: brightness(1.1);
    }

    /* Responsive */
    @media (max-width: 600px) {
        :global(html.chatbot-active-scroll-lock), 
        :global(body.chatbot-active-scroll-lock) {
            overflow: hidden !important;
        }

        .chatbot-wrapper {
            bottom: 20px;
            right: 20px;
        }

        .whatsapp-float-badge {
            width: 21px;
            height: 21px;
            font-size: 0.75rem;
            top: -4px;
            left: -4px;
            border-width: 1.5px;
        }

        .chatbot-toggle-btn {
            width: 50px;
            height: 50px;
            font-size: 1.3rem;
        }

        .chatbot-window {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100vw;
            height: auto;
            max-width: none;
            border-radius: 0;
            border: none;
            z-index: 10005;
            opacity: 1;
            visibility: hidden;
            transform: translateY(100%);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.35s;
        }

        .chatbot-input-form {
            padding: 0.75rem 1rem calc(1.5rem + env(safe-area-inset-bottom)) 1rem;
        }

        .chatbot-window.active {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        /* Ocultar botones flotantes cuando el chat está abierto */
        .chatbot-wrapper.active-chat .chatbot-toggle-btn,
        .chatbot-wrapper.active-chat .whatsapp-float-badge {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
    }
</style>

<script>
    // Carga diferida y optimizada del asistente de IA
    window.addEventListener('load', () => {
        let loaded = false;
        
        const loadChatbot = () => {
            if (loaded) return;
            loaded = true;
            
            // Importar dinámicamente el script del chatbot
            import('../scripts/chatbot');
            
            // Eliminar listeners de interacción
            window.removeEventListener('scroll', loadChatbot);
            document.removeEventListener('touchstart', loadChatbot);
            document.removeEventListener('mousemove', loadChatbot);
        };

        // Cargar tras 2.5 segundos de inactividad
        setTimeout(loadChatbot, 2500);

        // O al primer gesto del usuario
        window.addEventListener('scroll', loadChatbot, { passive: true });
        document.addEventListener('touchstart', loadChatbot, { passive: true });
        document.addEventListener('mousemove', loadChatbot, { passive: true });
    });
</script>

