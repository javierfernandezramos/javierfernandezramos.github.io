---
const { activePage } = Astro.props;
---
<header id="navbar">
    <div class="container">
        <a href="/" class="logo">JaviPhoto</a>
        <button class="menu-toggle" id="mobile-menu-btn" aria-label="Abrir menú de navegación">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <nav class="nav-links" id="nav-links">

            
            <div class="nav-links-inner">
                <a href="/" class={activePage === 'inicio' ? 'active' : ''}><i class="fa-solid fa-house"></i> Inicio</a>
                <a href="/galeria" class={activePage === 'galeria' ? 'active' : ''}><i class="fa-solid fa-image"></i> Galería</a>
                <a href="/videos" class={activePage === 'videos' ? 'active' : ''}><i class="fa-solid fa-play"></i> Vídeos</a>
                <a href="/servicios" class={activePage === 'servicios' ? 'active' : ''}><i class="fa-solid fa-camera"></i> Servicios</a>
                <a href="/articulos" class={activePage === 'articulos' ? 'active' : ''}><i class="fa-solid fa-newspaper"></i> Artículos</a>
                <a href="/contacto" class={activePage === 'contacto' ? 'active' : ''}><i class="fa-solid fa-paper-plane"></i> Contacto</a>
            </div>
        </nav>
    </div>
</header>

<style>
    .desktop-hidden {
        display: none;
    }

    @media (max-width: 1037px) {
        .desktop-hidden {
            display: block;
        }
        
        .nav-links-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        .nav-links-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }
    }
</style>
