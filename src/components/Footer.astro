                <a href="/" class="logo">JaviPhoto</a>
                <p class="brand-sub">Fotografía Profesional</p>
            </div>
            <div class="social-links-premium">
                <a href="https://www.instagram.com/javier.fzr/" target="_blank" aria-label="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="mailto:javierfernandezramos9@gmail.com" aria-label="Email" id="footer-gmail-link">
                    <i class="fas fa-envelope"></i>
                </a>
                <a href="https://www.tiktok.com/@javier.fzr" target="_blank" aria-label="TikTok">
                    <i class="fab fa-tiktok"></i>
