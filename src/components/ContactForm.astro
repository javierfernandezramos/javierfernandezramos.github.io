---
interface Props {
    id?: string;
    title?: string;
    subtitle?: string;
    buttonText?: string;
    formSubjectPrefix?: string;
}

const {
    id = "contacto",
    title = "Presupuesto Personalizado",
    subtitle = "Cuéntame qué tienes en mente y diseñaré una propuesta a medida para ti.",
    buttonText = "Enviar Solicitud",
    formSubjectPrefix = "Contacto"
} = Astro.props;

// Compute unique IDs for fields to allow multiple forms on the same page or unique labeling
const formId = `form-${id}`;
const nameId = `${id}-name`;
const phoneId = `${id}-phone`;
const emailId = `${id}-email`;
const subjectId = `${id}-asunto`;
const messageId = `${id}-mensaje`;
const statusId = `${id}-status`;
---

<section id={`formulario-${id}`} class="section-padding reveal contact-form-section">
    <div class="container">
        {title && <h2 class="section-title">{title}</h2>}
        {subtitle && <p class="text-center form-subtitle">{subtitle}</p>}
        
        <div class="calculator-card" style="max-width: 800px; margin: 0 auto;">
            <form id={formId} class="luxury-form" data-subject-prefix={formSubjectPrefix}>
                <div class="input-grid-2">
                    <div class="input-group">
                        <label for={nameId}>Nombre Completo</label>
                        <div style="position: relative;">
                            <i class="fas fa-user"></i>
                            <input type="text" id={nameId} name="name" placeholder="Tu nombre..." required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label for={phoneId}>Teléfono</label>
                        <div style="position: relative;">
                            <i class="fas fa-phone"></i>
                            <input type="tel" id={phoneId} name="phone" placeholder="600 000 000..." required />
                        </div>
                    </div>
                </div>

                <div class="input-group">
                    <label for={emailId}>Correo Electrónico</label>
                    <div style="position: relative;">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id={emailId} name="email" placeholder="tu@email.com..." required />
                    </div>
                </div>

                <div class="input-group">
                    <label for={subjectId}>¿En qué puedo ayudarte?</label>
                    <div style="position: relative;">
                        <i class="fas fa-tag"></i>
                        <input type="text" id={subjectId} name="asunto" placeholder="Ej: Reportaje para club, Evento corporativo..." required />
                    </div>
                </div>

                <div class="input-group">
                    <label for={messageId}>Detalles del Proyecto / Idea</label>
                    <div class="textarea-wrapper">
                        <i class="fas fa-comment-alt message-icon"></i>
                        <textarea id={messageId} name="mensaje" placeholder="Cuéntame más sobre fechas, lugar y qué necesitas exactamente..." rows="5" required></textarea>
                    </div>
                </div>

                <button type="submit" class="btn submit-btn full-width">
                    {buttonText} <i class="fas fa-paper-plane"></i>
                </button>
                <p id={statusId} class="small-note text-center" style="margin-top: 1.5rem; color: var(--color-gold); display: none;"></p>
                <p class="small-note text-center" style="margin-top: 1.5rem; opacity: 0.6;">
                    Tu mensaje será enviado de forma segura y recibirás una respuesta lo antes posible.
                </p>
            </form>
        </div>
    </div>
</section>

<script define:vars={{ formId, nameId, phoneId, emailId, subjectId, messageId, statusId }}>
    const formElement = document.getElementById(formId);
    const statusElement = document.getElementById(statusId);
    const subjectPrefix = formElement?.getAttribute('data-subject-prefix') || 'Contacto';

    formElement?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const name = (document.getElementById(nameId)).value;
        const phone = (document.getElementById(phoneId)).value;
        const email = (document.getElementById(emailId)).value;
        const subject_input = (document.getElementById(subjectId)).value;
        const message = (document.getElementById(messageId)).value;
        const submitBtn = formElement.querySelector('button[type="submit"]');

        const formData = new FormData();
        formData.append('_subject', `${subjectPrefix}: ${subject_input}`);
        formData.append('cliente_nombre', name);
        formData.append('cliente_email', email);
        formData.append('cliente_telefono', phone);
        formData.append('asunto', subject_input);
        formData.append('mensaje', message);

        if (statusElement) {
            statusElement.textContent = 'Enviando solicitud...';
            statusElement.style.display = 'block';
            statusElement.style.color = 'var(--color-gold)';
        }

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Enviando... <i class="fas fa-spinner fa-spin"></i>';
        }

        try {
            const response = await fetch("https://formspree.io/f/xkoyqbdj", {
                method: "POST",
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                if (statusElement) {
                    statusElement.textContent = '¡Solicitud enviada con éxito! Me pondré en contacto contigo pronto.';
                    statusElement.style.color = 'var(--color-gold)';
                }
                if (submitBtn) {
                    submitBtn.innerHTML = '¡Enviado! <i class="fas fa-check"></i>';
                    submitBtn.style.backgroundColor = '#28a745';
                    submitBtn.style.borderColor = '#28a745';
                }
                formElement.reset();
            } else {
                throw new Error();
            }
        } catch (error) {
            if (statusElement) {
                statusElement.textContent = 'Error al enviar. Por favor, inténtalo de nuevo.';
                statusElement.style.color = '#ff6b6b';
            }
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = `Reintentar Envío <i class="fas fa-paper-plane"></i>`;
                submitBtn.style.backgroundColor = '';
                submitBtn.style.borderColor = '';
            }
        }
    });
</script>

<style>
    .calculator-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 2.5rem;
        backdrop-filter: blur(10px);
        position: relative;
    }

    @media (max-width: 850px) {
        .calculator-card {
            padding: 1.5rem !important;
        }
    }

    .input-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 600px) {
        .input-grid-2 {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }

    .input-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .input-group label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 0.8rem;
        color: var(--color-text-light);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .input-group i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-gold);
        font-size: 0.9rem;
        opacity: 0.6;
        transition: all 0.3s ease;
        pointer-events: none;
        z-index: 2;
    }

    .input-group input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 1rem 1rem 3.5rem;
        color: #fff;
        font-family: inherit;
        border-radius: 8px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
        backdrop-filter: blur(10px);
    }

    .input-group input:focus {
        outline: none;
        border-color: var(--color-gold);
        background: rgba(197, 160, 89, 0.08);
        box-shadow: 0 0 30px rgba(197, 160, 89, 0.15);
    }

    .input-group:focus-within label {
        color: var(--color-gold);
        transform: translateX(5px);
    }

    .input-group:focus-within i {
        opacity: 1;
        transform: translateY(-50%) scale(1.1);
    }

    .textarea-wrapper {
        position: relative;
    }

    .message-icon {
        top: 20px !important;
        transform: none !important;
    }

    textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1.2rem 1rem 1.2rem 3.5rem;
        color: #fff;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        backdrop-filter: blur(10px);
        outline: none;
        resize: none;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    textarea:focus {
        border-color: var(--color-gold);
        background: rgba(197, 160, 89, 0.08);
        box-shadow: 0 0 30px rgba(197, 160, 89, 0.15);
    }

    .full-width {
        width: 100%;
        margin-top: 1rem;
    }

    .form-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }
</style>
