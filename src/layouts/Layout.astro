---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/style.css';
import defaultOgImage from '../assets/Fotos/hero-image.webp';
import { contactInfo } from '../data/config';

interface Props {
	title: string;
    description?: string;
    activePage?: string;
    preloadImage?: string;
    noIndex?: boolean;
    ogImage?: string;
}

const { 
    title, 
    description = "JaviPhoto: Tu fotógrafo en Valencia. Especialista en retratos profesionales, cobertura de eventos corporativos y fotografía deportiva.", 
    activePage,
    preloadImage,
    noIndex = false,
    ogImage = defaultOgImage.src
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://javierfernandezramos.github.io/#person",
      "name": "Javier Fernández Ramos",
      "url": "https://javierfernandezramos.github.io/",
      "image": "https://javierfernandezramos.github.io/favicon.png",
      "sameAs": [
        contactInfo.instagramUrl,
        contactInfo.tiktokUrl
      ],
      "jobTitle": "Fotógrafo Profesional",
      "description": "Fotógrafo profesional en Valencia especializado en retratos, eventos deportivos y marca personal."
    },
    {
      "@type": "Organization",
      "@id": "https://javierfernandezramos.github.io/#organization",
      "name": "JaviPhoto",
      "url": "https://javierfernandezramos.github.io/",
      "logo": "https://javierfernandezramos.github.io/favicon.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": contactInfo.email,
        "contactType": "customer service"
      }
    },
    {
      "@type": "ProfessionalService",
      "name": "JaviPhoto - Javier Fernández Ramos",
      "image": "https://javierfernandezramos.github.io/favicon.png",
      "@id": "https://javierfernandezramos.github.io/",
      "url": "https://javierfernandezramos.github.io/",
      "telephone": contactInfo.phone,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Valencia",
        "addressRegion": "Valencia",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 39.4699,
        "longitude": -0.3763
      },
      "priceRange": "$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday"
        ],
        "opens": "00:00",
        "closes": "23:59"
      }
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
<head>
    <!-- Google Tag Manager -->
    <script type="text/partytown">(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NG65XNV9');</script>
    <!-- End Google Tag Manager -->


    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- DNS Prefetch & Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">

    <!-- Fuentes y Estilos (Optimizado no-bloqueante) -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;800&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;800&display=swap" media="print" onload="this.media='all'">
    
    <link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" media="print" onload="this.media='all'" crossorigin="anonymous">
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Robots meta tag for control indexing -->
    {noIndex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://javierfernandezramos.github.io/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://javierfernandezramos.github.io/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    {preloadImage && <link rel="preload" href={preloadImage} as="image" type="image/webp" />}

    <!-- Schema.org - Identidad y GEO (Optimización para LLMs) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>

<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NG65XNV9"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <div id="loader">
        <div class="spinner"></div>
    </div>

    <Header activePage={activePage} />

    <main>
        <slot />
    </main>

    <Footer />

    <div id="lightbox" class="lightbox">
        <div class="lightbox-wrapper">
            <button id="lightbox-close-red" class="lightbox-close-red" aria-label="Cerrar"><i class="fas fa-times"></i></button>
            <button id="lightbox-prev" class="lightbox-nav prev" aria-label="Foto anterior"><i class="fas fa-chevron-left"></i></button>
            <img class="lightbox-content" id="lightbox-img">
            <button id="lightbox-next" class="lightbox-nav next" aria-label="Foto siguiente"><i class="fas fa-chevron-right"></i></button>

            <div class="swipe-hint">
                <div class="hint-top"></div>
                <span class="hint-text">Desliza para navegar</span>
                <div class="hint-bottom"></div>
            </div>
        </div>
    </div>

    <!-- Botón de WhatsApp -->
    <a href={contactInfo.whatsappUrl} class="whatsapp-float" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>

    <!-- Botón Volver Arriba -->
    <button id="back-to-top" class="back-to-top" aria-label="Volver arriba">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script src="../scripts/script.js"></script>
</body>
</html>
