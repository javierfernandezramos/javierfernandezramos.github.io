---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Load all images from subfolders during build
const allImages = import.meta.glob<{ default: ImageMetadata }>("../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});

// Helper to filter images by folder and exclude thumbnails
const getImagesFromFolder = (folder: string) => {
    const images = Object.entries(allImages)
        .filter(([path]) => path.includes(`/Fotos/${folder}/`) && !path.includes("_thumb"))
        .map(([path, module]) => ({ path, module: module.default }));
        
    return images.sort((a, b) => {
        const getFileName = (p: string) => p.split('/').pop()?.toLowerCase() || '';
        const nameA = getFileName(a.path);
        const nameB = getFileName(b.path);
        
        // Priorizar si empieza por "first" o "f" seguido de un número, guión o guión bajo (ej: f1-..., f-..., first-...)
        const isPriority = (name: string) => name.startsWith('first') || /^f[\d-_]/.test(name);
        
        const aPriority = isPriority(nameA);
        const bPriority = isPriority(nameB);
        
        if (aPriority && !bPriority) return -1;
        if (!aPriority && bPriority) return 1;
        
        // Si ambos son prioridad o ninguno lo es, orden alfabetico normal
        return nameA.localeCompare(nameB);
    }).map(item => item.module);
};

const categories = [
    { id: "modelo", name: "Modelo", images: getImagesFromFolder("Modelo") },
    { id: "eventos", name: "Eventos", images: getImagesFromFolder("Eventos") },
    { id: "novios", name: "Novios", images: getImagesFromFolder("Novios") },
    { id: "deportes", name: "Deportes", images: getImagesFromFolder("Deportes") },
    { id: "marca", name: "Marca", images: getImagesFromFolder("Marca") },
];
---

<Layout
    title="Galería de Fotografía Javier Fernández Ramos"
    description="Explora las colecciones de fotografía de JaviPhoto en Valencia: Retratos, Eventos, Novios, Deportes y Marca Personal. Calidad visual y atención al detalle."
    activePage="galeria">
    <header class="gallery-page-header">
        <div class="container">
            <h1 class="section-title">Colecciones</h1>
        </div>
    </header>

    <div class="categories-menu-wrapper">
        <div class="container">
            <div class="categories-menu" id="categories-menu">
                {
                    categories.map((cat, index) => (
                        <a href={`#${cat.id}`} class={index === 0 ? "active" : ""} data-category={cat.id}>
                            {cat.name}
                        </a>
                    ))
                }
            </div>
        </div>
    </div>

    <section id="photo-grid-container" class="container section-padding reveal">
        {
            categories.map((cat) => (
                <div
                    class={`category-content masonry-layout ${cat.id === categories[0].id ? "is-visible" : ""}`}
                    id={`cat-${cat.id}`}>
                    {cat.images.map((img) => (
                        <div class="gallery-item reveal active masonry-item" data-src={img.src}>
                            <Image
                                src={img}
                                alt={`Fotografía de ${cat.name}`}
                                width={800}
                                loading="lazy"
                            />
                            <div class="overlay">
                                <span>
                                    <i class="fa-solid fa-magnifying-glass" />
                                </span>
                            </div>
                        </div>
                    ))}
                </div>
            ))
        }
    </section>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            const menuLinks = document.querySelectorAll("#categories-menu a");
            const contents = document.querySelectorAll(".category-content");

            function layoutMasonry() {
                const grids = document.querySelectorAll('.masonry-layout.is-visible');
                grids.forEach(grid => {
                    const items = grid.querySelectorAll('.masonry-item');
                    items.forEach(item => {
                        const img = item.querySelector('img');
                        if (img) {
                            let h = img.getBoundingClientRect().height;
                            
                            // Si la imagen aún no se ha dibujado (h=0), precalculamos su altura real con su aspect ratio
                            if (h === 0 && img.getAttribute('width') && img.getAttribute('height')) {
                                const w = item.getBoundingClientRect().width;
                                const ratio = img.getAttribute('height') / img.getAttribute('width');
                                h = w * ratio;
                            }

                            if (h > 0) {
                                // Reducimos el gap vertical para que estén más juntas
                                const gap = window.innerWidth > 600 ? 16 : 6; 
                                const span = Math.ceil(h + gap);
                                item.style.gridRowEnd = `span ${span}`;
                            }
                        }
                    });
                });
            }

            // Ejecutar en carga y resize
            window.addEventListener('load', layoutMasonry);
            window.addEventListener('resize', layoutMasonry);

            // Ejecutar a medida que cargan las imágenes
            document.querySelectorAll('.masonry-item img').forEach(img => {
                if(img.complete) {
                    layoutMasonry();
                } else {
                    img.addEventListener('load', layoutMasonry);
                }
            });

            menuLinks.forEach((link) => {
                link.addEventListener("click", (e) => {
                    e.preventDefault();
                    const targetId = link.getAttribute("data-category");

                    // Update active class
                    menuLinks.forEach((l) => l.classList.remove("active"));
                    link.classList.add("active");

                    // Show/Hide content
                    contents.forEach((content) => {
                        if (content.id === `cat-${targetId}`) {
                            content.classList.add("is-visible");
                        } else {
                            content.classList.remove("is-visible");
                        }
                    });

                    // Recalcular layout inmediatamente para evitar parpadeos y evitar que el navegador cargue todas las imágenes a la vez por estar apiladas
                    layoutMasonry();

                    // Update URL without reloading (optional, but good for UX)
                    if (targetId) {
                        const newUrl = new URL(window.location.href);
                        newUrl.searchParams.set('filter', targetId);
                        window.history.replaceState({}, '', newUrl);
                    }

                    // Scroll back to the top of the grid with offset for sticky menus
                    const gridContainer = document.getElementById('photo-grid-container');
                    if (gridContainer) {
                        const headerOffset = 150;
                        const elementPosition = gridContainer.getBoundingClientRect().top;
                        const offsetPosition = elementPosition + window.scrollY - headerOffset;

                        window.scrollTo({
                            top: offsetPosition,
                            behavior: "smooth"
                        });
                    }
                });
            });

            // Handle initial filter from URL
            const urlParams = new URLSearchParams(window.location.search);
            const filterParam = urlParams.get('filter');
            if (filterParam) {
                const targetLink = document.querySelector(`#categories-menu a[data-category="${filterParam}"]`);
                if (targetLink) {
                    targetLink.click();
                    // Smooth scroll to grid if needed
                    setTimeout(() => {
                        const gridContainer = document.getElementById('photo-grid-container');
                        if (gridContainer) {
                            gridContainer.scrollIntoView({ behavior: 'smooth' });
                        }
                    }, 500);
                }
            }
        });

        function triggerHint() {
            const menu = document.getElementById("categories-menu");
            if (menu && window.innerWidth < 900) {
                // Pequeño retardo inicial
                setTimeout(() => {
                    // Scroll hacia la derecha
                    menu.scrollTo({
                        left: 100,
                        behavior: "smooth",
                    });

                    // Volver al inicio tras el "vistazo"
                    setTimeout(() => {
                        menu.scrollTo({
                            left: 0,
                            behavior: "smooth",
                        });
                    }, 800);
                }, 1000);
            }
        }

        // Lanzar el hint al cargar
        triggerHint();
    </script>
</Layout>

<style>
    .gallery-page-header {
        padding-top: 120px;
        text-align: center;
    }

    .categories-menu-wrapper {
        text-align: center;
        width: 100%;
        position: sticky;
        top: 80px;
        z-index: 2000;
        background: rgba(10, 10, 10, 0.9);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: top 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
        margin-bottom: 2rem;
    }

    :global(#navbar.scrolled) + main .categories-menu-wrapper {
        top: 64px;
        background: rgba(10, 10, 10, 0.95);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    @media (max-width: 1037px) {
        .categories-menu-wrapper {
            top: 76px;
        }
        :global(#navbar.scrolled) + main .categories-menu-wrapper {
            top: 56px;
        }
    }

    .categories-menu {
        display: inline-flex;
        justify-content: center;
        max-width: 100%;
        gap: 0.8rem;
        padding: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        overflow-x: auto;
        white-space: nowrap;
        /* Scrollbar Firefox */
        scrollbar-color: rgba(197, 160, 89, 0.7) rgba(255, 255, 255, 0.03);
        scrollbar-width: thin;
    }

    @media (min-width: 769px) {
        .categories-menu {
            justify-content: center;
        }
    }

    /* Scrollbar Webkit (Chrome/Safari/Edge) */
    .categories-menu::-webkit-scrollbar {
        height: 6px;
    }

    .categories-menu::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
    }

    .categories-menu::-webkit-scrollbar-thumb {
        background: rgba(197, 160, 89, 0.7);
        border-radius: 10px;
    }

    .categories-menu::-webkit-scrollbar-thumb:hover {
        background: var(--color-gold);
    }

    .categories-menu a {
        flex: 0 0 auto;
        padding: 0.5rem 1.2rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        text-transform: uppercase;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 1px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        color: var(--color-text-light);
        background: rgba(255, 255, 255, 0.02);
    }

    .categories-menu a:hover,
    .categories-menu a.active {
        border-color: var(--color-gold);
        color: #000;
        background: var(--color-gold);
    }

    @media (max-width: 768px) {
        .categories-menu {
            justify-content: flex-start;
            padding-bottom: 1.5rem;
            gap: 0.6rem;
        }

        .categories-menu a {
            padding: 0.5rem 1rem;
            font-size: 0.75rem;
        }
    }

    .category-content {
        display: none !important;
    }

    .masonry-layout.is-visible {
        display: grid !important;
    }

    /* Maximizar ancho en móvil */
    @media (max-width: 600px) {
        .container {
            width: 98% !important;
            padding: 0 4px !important;
        }
        .gallery-grid {
            column-gap: 4px !important;
        }
        .gallery-item {
            margin-bottom: 4px !important;
        }
    }

    /* Eliminar fondo negro feo */
    .gallery-item {
        background-color: transparent !important;
    }

    /* --- JS MASONRY GRID (Mantiene aspecto sin recortar, pero ordena de izq a der) --- */
    .masonry-layout {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        column-gap: 1rem;
        grid-auto-rows: 1px; /* Precisión de 1px para el cálculo de JS */
        row-gap: 0;
        align-items: start;
        padding: 1rem 0 4rem;
    }

    .masonry-item {
        margin-bottom: 0 !important; /* Espacio vertical controlado por JS */
        grid-row-end: span 400; /* Altura por defecto para evitar que se apilen y fuercen la carga masiva */
    }


    @media (max-width: 850px) {
        .masonry-layout {
            grid-template-columns: repeat(2, 1fr);
            column-gap: 1rem;
        }
    }

    @media (max-width: 600px) {
        .masonry-layout {
            column-gap: 4px;
        }
    }
</style>
