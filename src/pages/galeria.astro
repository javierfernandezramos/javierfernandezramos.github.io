---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Load all images from subfolders during build
const allImages = import.meta.glob<{ default: ImageMetadata }>('../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });

// Helper to filter images by folder and exclude thumbnails
const getImagesFromFolder = (folder: string) => {
    return Object.entries(allImages)
        .filter(([path]) => path.includes(`/Fotos/${folder}/`) && !path.includes('_thumb'))
        .map(([_, module]) => module.default);
};

const categories = [
    { id: 'modelo', name: 'Modelo', images: getImagesFromFolder('Modelo') },
    { id: 'eventos', name: 'Eventos', images: getImagesFromFolder('Eventos') },
    { id: 'novios', name: 'Novios', images: getImagesFromFolder('Novios') },
    { id: 'deportes', name: 'Deportes', images: getImagesFromFolder('Deportes') },
    { id: 'marca', name: 'Marca', images: getImagesFromFolder('Marca') },
];
---

<Layout 
    title="Galería de Fotografía en Valencia | Portafolio Fotográfico" 
    description="Explora las colecciones de fotografía de JaviPhoto en Valencia: Retratos, Eventos, Novios, Deportes y Marca Personal. Calidad visual y atención al detalle."
    activePage="galeria"
>
    <header class="gallery-page-header">
        <div class="container">
            <h1 class="section-title">Colecciones</h1>
        </div>
    </header>

    <div class="categories-menu-wrapper reveal">
        <div class="container">
            <div class="categories-menu" id="categories-menu">
                {categories.map((cat, index) => (
                    <a href={`#${cat.id}`} class={index === 0 ? 'active' : ''} data-category={cat.id}>
                        {cat.name}
                    </a>
                ))}
            </div>
        </div>
    </div>

    <section id="photo-grid-container" class="container section-padding reveal">
        {categories.map((cat) => (
            <div class="category-content gallery-grid" id={`cat-${cat.id}`} style={cat.id === categories[0].id ? 'display: block;' : 'display: none;'}>
                {cat.images.map((img) => (
                    <div class="gallery-item reveal active" data-src={img.src}>
                        <Image src={img} alt={`Fotografía de ${cat.name}`} width={800} class="loaded" data-src={img.src} />
                        <div class="overlay"><span><i class="fa-solid fa-magnifying-glass"></i></span></div>
                    </div>
                ))}
            </div>
        ))}
    </section>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const menuLinks = document.querySelectorAll('#categories-menu a');
            const contents = document.querySelectorAll('.category-content');

            menuLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = link.getAttribute('data-category');

                    // Update active class
                    menuLinks.forEach(l => l.classList.remove('active'));
                    link.classList.add('active');

                    // Show/Hide content
                    contents.forEach(content => {
                        if (content.id === `cat-${targetId}`) {
                            content.style.display = 'block';
                        } else {
                            content.style.display = 'none';
                        }
                    });
                });
            });

        });

        function triggerHint() {
            const menu = document.getElementById('categories-menu');
            if (menu && window.innerWidth < 900) {
                // Pequeño retardo inicial
                setTimeout(() => {
                    // Scroll hacia la derecha
                    menu.scrollTo({
                        left: 100,
                        behavior: 'smooth'
                    });
                    
                    // Volver al inicio tras el "vistazo"
                    setTimeout(() => {
                        menu.scrollTo({
                            left: 0,
                            behavior: 'smooth'
                        });
                    }, 800);
                }, 1000);
            }
        }

        // Lanzar el hint al cargar
        triggerHint();
    </script>
</Layout>

<style>
    .gallery-page-header {
        padding-top: 120px;
        text-align: center;
    }

    .categories-menu-wrapper {
        text-align: center;
        width: 100%;
    }

    .categories-menu {
        display: inline-flex;
        justify-content: flex-start;
        max-width: 100%;
        gap: 1rem;
        padding: 2rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        margin-bottom: 2rem;
        overflow-x: auto;
        white-space: nowrap;
        /* Scrollbar Firefox */
        scrollbar-color: rgba(197, 160, 89, 0.7) rgba(255, 255, 255, 0.03);
        scrollbar-width: thin;
    }

    /* Scrollbar Webkit (Chrome/Safari/Edge) */
    .categories-menu::-webkit-scrollbar {
        height: 6px;
    }

    .categories-menu::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
    }

    .categories-menu::-webkit-scrollbar-thumb {
        background: rgba(197, 160, 89, 0.7);
        border-radius: 10px;
    }

    .categories-menu::-webkit-scrollbar-thumb:hover {
        background: var(--color-gold);
    }

    .categories-menu a {
        flex: 0 0 auto;
        padding: 0.7rem 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        text-transform: uppercase;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 1px;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        color: var(--color-text-light);
        background: rgba(255, 255, 255, 0.02);
    }

    .categories-menu a:hover,
    .categories-menu a.active {
        border-color: var(--color-gold);
        color: #000;
        background: var(--color-gold);
    }

    @media (max-width: 768px) {
        .categories-menu {
            justify-content: flex-start;
            padding-bottom: 1.5rem;
            gap: 0.6rem;
        }

        .categories-menu a {
            padding: 0.5rem 1rem;
            font-size: 0.75rem;
        }
    }

    .category-content {
        display: none;
    }

    /* Maximizar ancho en móvil */
    @media (max-width: 600px) {
        .container {
            width: 98% !important;
            padding: 0 4px !important;
        }
        .gallery-grid {
            column-gap: 4px !important;
        }
        .gallery-item {
            margin-bottom: 4px !important;
        }
    }

    /* Eliminar fondo negro feo */
    .gallery-item {
        background-color: transparent !important;
    }
</style>
