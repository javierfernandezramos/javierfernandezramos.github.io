---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/404');
}

let entry: any;
let Content: any;

if (import.meta.env.DEV) {
  const postsObj = import.meta.glob('../../content/articulos/*.md', { eager: true });
  const imagesObj = import.meta.glob('../../assets/Fotos/**/*', { eager: true });
  
  const matchedEntry = Object.entries(postsObj).find(([filepath]) => {
    const filename = filepath.split('/').pop() || filepath.split('\\').pop() || '';
    return filename.replace('.md', '') === slug;
  });
  
  if (!matchedEntry) {
    return Astro.redirect('/404');
  }
  
  const [filepath, post]: [string, any] = matchedEntry;
  const imgPath = post.frontmatter.image;
  const imgModule = imgPath ? imagesObj[imgPath] as any : undefined;
  const resolvedImage = imgModule ? imgModule.default : undefined;
  
  entry = {
    id: slug,
    data: {
      title: post.frontmatter.title,
      description: post.frontmatter.description,
      pubDate: new Date(post.frontmatter.pubDate),
      image: resolvedImage,
      tags: post.frontmatter.tags || []
    }
  };
  Content = post.default;
} else {
  const realEntry = await getEntry('articulos', slug);
  if (!realEntry) {
    return Astro.redirect('/404');
  }
  entry = realEntry;
  const rendered = await render(realEntry);
  Content = rendered.Content;
}

const title = entry.data.title;
const description = entry.data.description;
const ogImage = entry.data.image ? entry.data.image.src : undefined;

// Obtener otros artículos para enlazarlos al final
let todosLosArticulos = [];
if (import.meta.env.DEV) {
  const postsObj = import.meta.glob('../../content/articulos/*.md', { eager: true });
  const imagesObj = import.meta.glob('../../assets/Fotos/**/*', { eager: true });
  
  todosLosArticulos = Object.entries(postsObj).map(([filepath, post]: [string, any]) => {
    const filename = filepath.split('/').pop() || filepath.split('\\').pop() || '';
    const imgPath = post.frontmatter.image;
    const imgModule = imgPath ? imagesObj[imgPath] as any : undefined;
    const resolvedImage = imgModule ? imgModule.default : undefined;
    
    return {
      id: filename.replace('.md', ''),
      data: {
        title: post.frontmatter.title,
        description: post.frontmatter.description,
        pubDate: new Date(post.frontmatter.pubDate),
        image: resolvedImage,
        tags: post.frontmatter.tags || []
      }
    };
  });
} else {
  todosLosArticulos = await getCollection('articulos');
}

const articulosRelacionados = todosLosArticulos
  .filter(art => art.id !== entry.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Schema específico para el artículo
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": ogImage ? (ogImage.startsWith('http') ? ogImage : `https://javiphoto.es${ogImage}`) : 'https://javiphoto.es/assets/Fotos/hero-image.webp',
  "datePublished": entry.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Javier Fernández Ramos",
    "url": "https://javiphoto.es"
  },
  "publisher": {
    "@type": "Organization",
    "name": "JaviPhoto",
    "logo": {
      "@type": "ImageObject",
      "url": "https://javiphoto.es/favicon.ico"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://javiphoto.es/articulos/${entry.id}`
  }
};
---

<Layout title={title} description={description} activePage="articulos" ogImage={ogImage}>
    <!-- Inyección del Schema de artículo -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <article class="article-single">
        <header class="article-header article-single-header">
            <div class="container">
                <div class="header-content reveal">
                    <span class="article-meta">
                        {entry.data.pubDate.toLocaleDateString('es-ES', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        })}
                    </span>
                    <h1>{entry.data.title}</h1>
                    <p class="lead">{entry.data.description}</p>
                </div>
            </div>
        </header>

        <div class="container">
            <div class="article-body reveal">
                <Content />
                
                <div class="article-footer-cta">
                    <hr />
                    <h3>¿Te gusta lo que ves?</h3>
                    <p>Si quieres una sesión profesional en Valencia similar a lo que has leído, hablemos.</p>
                    <a href="/contacto" class="btn">Reservar Sesión <i class="fas fa-calendar-alt"></i></a>
                </div>
            </div>

            {articulosRelacionados.length > 0 && (
                <div class="related-articles-section reveal">
                    <div class="section-divider"></div>
                    <h2>Otros artículos que podrían interesarte</h2>
                    <div class="related-grid">
                        {articulosRelacionados.map(art => (
                            <a href={`/articulos/${art.id}`} class="related-card">
                                <div class="related-card-img-wrapper">
                                    <img src={art.data.image ? art.data.image.src : '/assets/Fotos/hero-image.webp'} alt={art.data.title} />
                                </div>
                                <div class="related-card-content">
                                    <span class="related-date">
                                        {art.data.pubDate.toLocaleDateString('es-ES', {
                                            year: 'numeric',
                                            month: 'short',
                                            day: 'numeric'
                                        })}
                                    </span>
                                    <h3>{art.data.title}</h3>
                                    <p>{art.data.description}</p>
                                </div>
                            </a>
                        ))}
                    </div>
                </div>
            )}

            <div class="back-to-articles-wrapper reveal">
                <a href="/articulos" class="back-btn">
                    <i class="fas fa-arrow-left"></i> Volver a los artículos
                </a>
            </div>
        </div>
    </article>
</Layout>

<style define:vars={{ headerImg: `url(${entry.data.image ? entry.data.image.src : '/assets/Fotos/hero-image.webp'})` }}>
    .article-single-header {
        background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), var(--headerImg);
    }

    .article-header {
        height: 60vh;
        min-height: 450px;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        text-align: center;
        margin-bottom: 4rem;
        padding-top: 100px; /* Espacio para el navbar */
    }

    .header-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .article-meta {
        color: var(--color-gold);
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 0.8rem;
        font-weight: 700;
        display: block;
        margin-bottom: 1.5rem;
    }

    .article-header h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        color: #fff;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        font-weight: 800;
    }

    .lead {
        font-size: 1.2rem;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 300;
    }

    .article-body {
        max-width: 800px;
        margin: 0 auto 4rem;
        font-size: 1.15rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.85);
    }

    /* Estilos para el contenido Markdown */
    .article-body :global(h2) {
        color: #fff;
        font-size: 2rem;
        margin: 3rem 0 1.5rem;
        font-weight: 700;
    }

    .article-body :global(h3) {
        color: var(--color-gold);
        font-size: 1.5rem;
        margin: 2rem 0 1rem;
    }

    .article-body :global(p) {
        margin-bottom: 1.5rem;
    }

    .article-body :global(strong) {
        color: #fff;
    }

    .article-body :global(ul) {
        margin-bottom: 2rem;
        list-style: none;
        padding-left: 0;
    }

    .article-body :global(li) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
        position: relative;
    }

    .article-body :global(li::before) {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--color-gold);
    }

    .article-footer-cta {
        margin-top: 5rem;
        text-align: center;
        padding: 3rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .article-footer-cta hr {
        border: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
        margin-bottom: 3rem;
        opacity: 0.3;
    }

    .article-footer-cta h3 {
        margin-top: 0;
    }

    .article-footer-cta p {
        margin-bottom: 2rem;
    }

    /* Estilos de artículos relacionados */
    .related-articles-section {
        margin-top: 4rem;
        margin-bottom: 4rem;
    }

    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        margin-bottom: 4rem;
    }

    .related-articles-section h2 {
        font-size: 2rem;
        color: #fff;
        text-align: center;
        margin-bottom: 3rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
    }

    .related-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), 
                    border-color 0.3s ease, 
                    box-shadow 0.3s ease;
    }

    .related-card:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

    .related-card-img-wrapper {
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.2);
    }

    .related-card-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .related-card:hover .related-card-img-wrapper img {
        transform: scale(1.05);
    }

    .related-card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .related-date {
        color: var(--color-gold);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        margin-bottom: 0.8rem;
        display: block;
    }

    .related-card-content h3 {
        font-size: 1.25rem;
        color: #fff;
        margin: 0 0 0.8rem 0;
        line-height: 1.3;
        font-weight: 700;
        transition: color 0.3s ease;
    }

    .related-card:hover .related-card-content h3 {
        color: var(--color-gold);
    }

    .related-card-content p {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Botón volver */
    .back-to-articles-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
        margin-bottom: 6rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem 2rem;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 1px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        background: #fff;
        color: #000;
        border-color: #fff;
        transform: translateY(-2px);
    }

    .back-btn i {
        transition: transform 0.3s ease;
    }

    .back-btn:hover i {
        transform: translateX(-4px);
    }

    @media (max-width: 768px) {
        .article-header {
            height: 50vh;
        }
        
        .article-body {
            font-size: 1.05rem;
            margin-bottom: 2rem;
        }

        .related-articles-section h2 {
            font-size: 1.6rem;
            margin-bottom: 2rem;
        }
        
        .related-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        
        .back-to-articles-wrapper {
            margin-top: 2rem;
            margin-bottom: 4rem;
        }
    }
</style>
