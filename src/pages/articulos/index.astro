---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

export const prerender = false;

let articulos = [];
if (import.meta.env.DEV) {
  const postsObj = import.meta.glob('../../content/articulos/*.md', { eager: true });
  const imagesObj = import.meta.glob('../../assets/Fotos/**/*', { eager: true });
  
  articulos = Object.entries(postsObj).map(([filepath, post]: [string, any]) => {
    const filename = filepath.split('/').pop() || filepath.split('\\').pop() || '';
    const imgPath = post.frontmatter.image;
    // import.meta.glob devuelve el módulo de imagen directamente (sin .default)
    const resolvedImage = imgPath ? (imagesObj[imgPath] as any) : undefined;
    
    return {
      id: filename.replace('.md', ''),
      data: {
        title: post.frontmatter.title,
        description: post.frontmatter.description,
        pubDate: new Date(post.frontmatter.pubDate),
        image: resolvedImage,
        tags: post.frontmatter.tags || []
      }
    };
  });
} else {
  articulos = await getCollection('articulos');
}

// Ordenar por fecha descendente
articulos.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Artículos y Consejos de Fotografía";
const description = "Explora mis artículos sobre fotografía en Valencia: consejos, mejores localizaciones y guías para tus sesiones profesionales.";
---

<Layout title={title} description={description} activePage="articulos">
    <header class="articles-page-header">
        <div class="container">
            <h1 class="section-title reveal">Artículos</h1>
            <p class="section-intro text-center reveal">
                Consejos, guías y localizaciones para amantes de la fotografía y profesionales en Valencia.
            </p>
        </div>
    </header>

    <section class="section-padding pt-0">
        <div class="container">
            <div class="articles-grid reveal">
                {articulos.map((articulo) => (
                    <a href={`/articulos/${articulo.id}`} class="article-card">
                        <div class="article-image-wrapper">
                            {articulo.data.image ? (
                                <Image 
                                    src={articulo.data.image} 
                                    alt={articulo.data.title} 
                                    class="article-image"
                                    width={600}
                                    height={400}
                                    format="webp"
                                />
                            ) : (
                                <div class="article-image-fallback">
                                    <i class="fas fa-camera"></i>
                                </div>
                            )}
                        </div>
                        <div class="article-content">
                            <span class="article-date">
                                {articulo.data.pubDate.toLocaleDateString('es-ES', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric'
                                })}
                            </span>
                            <h2 class="article-title">{articulo.data.title}</h2>
                            <p class="article-description">{articulo.data.description}</p>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>

<style>
    .articles-page-header {
        padding-top: 140px; /* Suficiente espacio para el navbar fijo */
        text-align: center;
    }

    .pt-0 {
        padding-top: 0 !important;
    }

    .section-intro {
        max-width: 700px;
        margin: -2rem auto 4rem;
        color: var(--color-text-light);
        font-size: 1.1rem;
    }

    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2.5rem;
        margin-top: 2rem;
    }

    .article-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), 
                    border-color 0.3s ease, 
                    box-shadow 0.3s ease;
        height: 100%;
    }

    .article-card:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
    }

    .article-image-wrapper {
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.2);
    }

    .article-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .article-card:hover .article-image {
        transform: scale(1.05);
    }

    .article-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .article-date {
        color: var(--color-gold);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        margin-bottom: 0.8rem;
        display: block;
    }

    .article-title {
        font-size: 1.3rem;
        color: #fff;
        margin: 0 0 0.8rem 0;
        line-height: 1.3;
        font-weight: 700;
        transition: color 0.3s ease;
    }

    .article-card:hover .article-title {
        color: var(--color-gold);
    }

    .article-description {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .article-image-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.02);
        color: var(--color-gold);
        font-size: 2.5rem;
    }

    @media (max-width: 768px) {
        .articles-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }
</style>
