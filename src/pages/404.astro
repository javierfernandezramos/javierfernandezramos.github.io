---
import Layout from '../layouts/Layout.astro';
import heroImg from '../assets/Fotos/hero-image.webp';
---

<Layout title="404 - Página no encontrada" description="Lo sentimos, la página que buscas no existe.">
    <section class="error-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.7)), url(${heroImg.src});`}>
        <div class="container">
            <h1 class="reveal">404</h1>
            <h2 class="reveal">Página no encontrada</h2>
            <p class="reveal">Parece que te has perdido en el enfoque. No te preocupes, siempre podemos volver al inicio para retomar la sesión.</p>
            <div class="reveal">
                <a href="/" class="btn luxury-gallery-btn"><i class="fas fa-arrow-left"></i> Volver al Inicio</a>
            </div>
        </div>
    </section>

    <style>
        .error-hero {
            height: 100svh;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            padding: 80px 1.5rem 0;
        }

        .error-hero h1 {
            font-size: clamp(5.5rem, 22vw, 11rem);
            background: linear-gradient(to right, #fff, var(--color-gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 0.9;
            margin-bottom: 0.5rem;
            font-weight: 800;
            letter-spacing: -8px;
            filter: drop-shadow(0 15px 30px rgba(0,0,0,0.5));
        }

        .error-hero h2 {
            font-size: clamp(0.9rem, 4vw, 1.6rem);
            margin-bottom: 1.5rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: rgba(255, 255, 255, 0.9);
        }

        .error-hero p {
            margin-bottom: 2.5rem;
            color: rgba(255, 255, 255, 0.8);
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            font-size: clamp(0.95rem, 3vw, 1.1rem);
            line-height: 1.8;
            font-weight: 300;
        }

        @media (max-width: 768px) {
            .error-hero {
                background-attachment: scroll;
            }
            .error-hero h1 {
                letter-spacing: -2px;
            }
        }
    </style>
</Layout>
