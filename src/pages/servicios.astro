---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import type { ImageMetadata } from "astro";

// Import images for services
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => galleryImages[`../assets/Fotos/${path}`]?.default;
const heroImg = getImg("hero-image.webp");
---

<Layout
    title="Servicios de Fotografía Profesional en Valencia"
    description="Descubre los servicios de fotografía en Valencia: desde retratos profesionales hasta cobertura de eventos y fotografía deportiva. Calidad y profesionalidad garantizada."
    activePage="servicios">
    <section class="services-hero">
        <div class="container">
            <h1 class="section-title reveal">Servicios de Fotografía en Valencia</h1>
            <p class="section-subtitle reveal">
                Capturando la excelencia en cada disciplina. Fotografía creativa y profesional en Valencia.
            </p>
        </div>
    </section>

    <div class="services-wrapper-mobile">
        <ServiceCard
            title="Fotógrafo Deportivo Valencia"
            tag="Velocidad y Acción"
            description="Especializado en capturar la adrenalina y la intensidad del deporte. Desde la rapidez en la pista de tenis hasta la emoción de cualquier disciplina deportiva."
            link="/servicios/fotografo-deportivo-valencia"
            galleryLink="/galeria?filter=deportes"
            image={getImg("Deportes/1.webp")}
        />

        <ServiceCard
            title="Fotógrafo Fitness Valencia"
            tag="Estética y Disciplina"
            description="Sesiones especializadas para atletas, modelos fitness y entrenadores. Resaltamos tu progreso y dedicación con una iluminación que potencia cada detalle de tu condición física."
            link="/servicios/fotografo-fitness-valencia"
            galleryLink="/galeria?filter=modelo"
            image={getImg("Modelo/f3-fit-modelo.webp")}
            reverse={true}
        />

        <ServiceCard
            title="Fotografo de eventos en Valencia"
            tag="Momentos Inolvidables"
            description="Cada evento tiene una historia única. Ofrezco una fotografía creativa en Valencia para eventos sociales, corporativos y lifestyle, buscando siempre la naturalidad y la esencia del momento."
            link="/servicios/fotografo-eventos-valencia"
            galleryLink="/galeria?filter=eventos"
            image={getImg("Eventos/3.webp")}
        />

        <ServiceCard
            title="Retrato Profesional Valencia"
            tag="Esencia Personal"
            description="Sesiones de retrato personalizadas para modelos, profesionales y marcas. Nos enfocamos en resaltar tu mejor versión a través de una iluminación experta y una dirección artística de primer nivel."
            link="/servicios/retratos-profesionales-valencia"
            galleryLink="/galeria?filter=modelo"
            image={getImg("Modelo/4.webp")}
            reverse={true}
        />

        <ServiceCard
            title="Fotografía de Marca y Negocios"
            tag="Identidad Corporativa"
            description="Ayudo a empresas y emprendedores a comunicar su valor a través de imágenes potentes. Desde fotografía de marca en Valencia hasta retratos corporativos y contenido para redes sociales."
            link="/servicios/fotografia-marca-personal-valencia"
            galleryLink="/galeria?filter=marca"
            image={getImg("cubas-31.webp")}
        />
    </div>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿No encuentras lo que buscas?</h2>
            <p class="cta-subtitle">Cuéntame tu idea y diseñaremos una sesión a tu medida.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Contactar Ahora <i class="fas fa-envelope"></i></a>
        </div>
    </section>

    <style>
        .services-hero {
            padding: 220px 0 60px !important;
            text-align: center;
        }

        .cta-subtitle {
            margin-bottom: 2rem;
        }

        @media (max-width: 1038px) {
            .services-hero {
                padding: 150px 0 40px !important;
            }
        }

        /* Slider de Servicios para Móvil */
        @media (max-width: 1038px) {
            .services-wrapper-mobile {
                display: flex;
                overflow-x: auto;
                overflow-y: hidden;
                scroll-snap-type: x mandatory;
                padding: 0.5rem 4% 2rem;
                gap: 1.2rem;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
                align-items: stretch;
            }

            .services-wrapper-mobile::-webkit-scrollbar {
                display: none;
            }

            #cta-servicios {
                padding: 3rem 0;
            }

            #cta-servicios h2 {
                font-size: 1.4rem;
                margin-bottom: 1.5rem;
            }

            /* Animación premium para el hint de servicios */
            @keyframes hintSwipe {
                0% {
                    transform: translateX(0);
                }
                30% {
                    transform: translateX(-80px);
                }
                100% {
                    transform: translateX(0);
                }
            }

            /* Aplicamos la animación a las tarjetas individuales para que no se "corte" el contenedor */
            .services-wrapper-mobile.hint-active :global(.service-detail-section) {
                animation: hintSwipe 1.4s cubic-bezier(0.45, 0.05, 0.55, 0.95);
            }
        }
    </style>
</Layout>
