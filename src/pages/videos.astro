---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="Producción de Vídeo en Valencia | Videógrafo Profesional" 
    description="Servicios de videografía profesional en Valencia. Cobertura de eventos, vídeos promocionales y contenido dinámico para marcas y particulares."
    activePage="videos"
>
    <main class="container">
        <header class="videos-page-header reveal" style="padding-top: 120px; text-align: center;">
            <h1 class="section-title">Film & Video</h1>
            <p class="videos-subtitle" style="text-align: center; color: var(--color-text-light); margin-bottom: 2rem;">Behind The Scenes & Oficiales</p>
        </header>

        <section class="videos-grid reveal" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 2rem 0;">
            <div class="video-card">
                <div style="position:relative;padding-top:177.77%;">
                    <iframe
                        src="https://player.mediadelivery.net/embed/640795/2c525299-3da1-4371-b640-667330e70a08?autoplay=false"
                        loading="lazy" style="border:0;position:absolute;top:0;height:100%;width:100%;"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label" style="text-align: center; margin-top: 1rem; color: var(--color-gold); text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem;">Video de Marca</div>
            </div>

            <div class="video-card">
                <div style="position:relative;padding-top:177.77%;">
                    <iframe
                        src="https://player.mediadelivery.net/embed/640795/734f90b7-9645-49db-9d9a-ed72a9e385f5?autoplay=false"
                        loading="lazy" style="border:0;position:absolute;top:0;height:100%;width:100%;"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label" style="text-align: center; margin-top: 1rem; color: var(--color-gold); text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem;">Behind the scenes</div>
            </div>

            <div class="video-card">
                <div style="position:relative;padding-top:177.77%;">
                    <iframe
                        src="https://player.mediadelivery.net/embed/640795/018f5325-ad69-4889-960f-1a12f0812395?autoplay=false"
                        loading="lazy" style="border:0;position:absolute;top:0;height:100%;width:100%;"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label" style="text-align: center; margin-top: 1rem; color: var(--color-gold); text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem;">Contenido Fitness</div>
            </div>
        </section>
    </main>

    <style>
        @media (max-width: 900px) {
            .videos-grid {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }
        @media (max-width: 600px) {
            .videos-grid {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
</Layout>
