---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Producción de Vídeo en Valencia - Videógrafo Profesional"
    description="Servicios de videografía profesional en Valencia. Cobertura de eventos, vídeos promocionales y contenido dinámico para marcas y particulares."
    activePage="videos">
    <main class="container">
        <header class="videos-page-header reveal">
            <h1 class="section-title">Film & Video</h1>
            <p class="videos-subtitle">
                Behind The Scenes & Oficiales
            </p>
        </header>

        <section class="videos-grid reveal">
            <div class="video-card">
                <div class="iframe-container">
                    <iframe
                        title="Video de Marca"
                        src="https://www.youtube.com/embed/aQj4YPqVwbY"
                        loading="eager"
                        class="video-iframe"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label">
                    Video de Marca
                </div>
            </div>

            <div class="video-card">
                <div class="iframe-container">
                    <iframe
                        title="Behind the scenes"
                        src="https://www.youtube.com/embed/81JkqXElx94"
                        loading="eager"
                        class="video-iframe"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label">
                    Behind the scenes
                </div>
            </div>

            <div class="video-card">
                <div class="iframe-container">
                    <iframe
                        title="Contenido Fitness"
                        src="https://www.youtube.com/embed/tjk4pEZq3Bs"
                        loading="eager"
                        class="video-iframe"
                        allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                        allowfullscreen="true"></iframe>
                </div>
                <div class="video-label">
                    Contenido Fitness
                </div>
            </div>
        </section>
    </main>

    <style>
        .videos-page-header {
            padding-top: 120px;
            text-align: center;
        }

        .videos-subtitle {
            text-align: center;
            color: var(--color-text-light);
            margin-bottom: 2rem;
        }

        .videos-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            padding: 2rem 0;
        }

        .iframe-container {
            position: relative;
            padding-top: 177.77%;
        }

        .video-iframe {
            border: 0;
            position: absolute;
            top: 0;
            height: 100%;
            width: 100%;
        }

        .video-label {
            text-align: center;
            margin-top: 1rem;
            color: var(--color-gold);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.8rem;
        }

        @media (max-width: 900px) {
            .videos-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        @media (max-width: 600px) {
            .videos-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</Layout>
