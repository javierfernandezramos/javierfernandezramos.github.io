---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>('../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });
const getImg = (path: string) => {
  const fullPath = `../assets/Fotos/${path}`;
  return galleryImages[fullPath]?.default;
};

const heroImg = getImg('hero-image.webp');
const sideImg = getImg('Modelo/11.webp');
---

<Layout 
    title="Contactar Fotógrafo en Valencia | Reservas y Presupuestos" 
    description="¿Buscas un fotógrafo en Valencia? Contacta con JaviPhoto para reservar tu sesión de fotos o solicitar un presupuesto personalizado para tu proyecto o evento."
    activePage="contacto"
>
    <section class="services-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('${heroImg?.src}'); background-size: cover; background-position: center; min-height: 50vh; display: flex; align-items: center; justify-content: center; text-align: center;`}>
        <div class="container">
            <h1 class="section-title reveal" style="color: white; margin-bottom: 1rem; text-shadow: 0 5px 15px rgba(0,0,0,0.5);">Reservar Fotógrafo en Valencia</h1>
            <p class="section-subtitle reveal" style="color: white; font-size: 1.1rem; font-weight: 400; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">Tu próximo gran proyecto comienza con un mensaje.</p>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <div class="contact-grid">
                <div class="contact-content-block">
                    <h2 class="minimal-title text-center">¿Por qué elegir a JaviPhoto?</h2>
                    <div class="editorial-body" style="text-align: left !important;">
                        <p>Si estás buscando <strong>fotógrafos en Valencia</strong> que combinen técnica, creatividad y un estilo moderno, has llegado al lugar indicado. Me especializo en capturar momentos únicos, ya sea en eventos deportivos, corporativos o sesiones de marca personal.</p>
                        <p><strong>Reservar un fotógrafo en Valencia</strong> con JaviPhoto es garantía de profesionalidad y resultados de alta calidad. Entiendo la importancia de cada imagen y trabajo estrechamente contigo para que el resultado final supere tus expectativas.</p>
                        <ul style="list-style: none; padding: 0; margin-top: 2rem;">
                            <li style="margin-bottom: 1.2rem;"><i class="fas fa-check-circle" style="color: var(--color-gold); margin-right: 12px;"></i> Entrega rápida de material optimizado.</li>
                            <li style="margin-bottom: 1.2rem;"><i class="fas fa-check-circle" style="color: var(--color-gold); margin-right: 12px;"></i> Equipamiento de última generación (Sony Alpha).</li>
                            <li style="margin-bottom: 1.2rem;"><i class="fas fa-check-circle" style="color: var(--color-gold); margin-right: 12px;"></i> Presupuestos claros y adaptados a tu proyecto.</li>
                        </ul>
                    </div>
                </div>
                <div class="acerca-img glass-frame">
                    <Image src={sideImg} alt="Sesión de fotos profesional Valencia - JaviPhoto" width={600} class="loaded" />
                </div>
            </div>
        </div>
    </section>

    <section id="formulario-contacto" class="section-padding reveal" style="background: var(--color-secondary);">
        <div class="container">
            <h2 class="section-title">Presupuesto Personalizado</h2>
            <p class="text-center" style="margin-bottom: 3rem; color: var(--color-text-light); max-width: 700px; margin-left: auto; margin-right: auto;">
                ¿Tu proyecto no encaja en los packs estándar? Cuéntame qué tienes en mente y diseñaré una propuesta a medida para ti.
            </p>
            
            <div class="calculator-card" style="max-width: 800px; margin: 0 auto;">
                <form id="contact-form" class="luxury-form">
                    <div class="input-grid-2">
                        <div class="input-group">
                            <label for="c-name">Nombre Completo</label>
                            <div style="position: relative;">
                                <i class="fas fa-user"></i>
                                <input type="text" id="c-name" name="name" placeholder="Tu nombre..." required />
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="c-phone">Teléfono</label>
                            <div style="position: relative;">
                                <i class="fas fa-phone"></i>
                                <input type="tel" id="c-phone" name="phone" placeholder="600 000 000..." required />
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="c-email">Correo Electrónico</label>
                        <div style="position: relative;">
                            <i class="fas fa-envelope"></i>
                            <input type="email" id="c-email" name="email" placeholder="tu@email.com..." required />
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="c-asunto">¿En qué puedo ayudarte?</label>
                        <div style="position: relative;">
                            <i class="fas fa-tag"></i>
                            <input type="text" id="c-asunto" name="asunto" placeholder="Ej: Reportaje para club, Evento corporativo..." required />
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="c-mensaje">Detalles del Proyecto</label>
                        <div style="position: relative;">
                            <i class="fas fa-comment-alt" style="top: 20px; transform: none;"></i>
                            <textarea id="c-mensaje" name="mensaje" placeholder="Cuéntame más sobre fechas, lugar y qué necesitas exactamente..." rows="5" required style="width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); padding: 1.2rem 1rem 1.2rem 3.5rem; color: #fff; border-radius: 8px; font-family: inherit; font-size: 1rem; backdrop-filter: blur(10px); outline: none; resize: none;"></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn submit-btn" style="width: 100%; margin-top: 1rem;">
                        Enviar Solicitud de Presupuesto <i class="fas fa-paper-plane"></i>
                    </button>
                    <p id="form-status" class="small-note text-center" style="margin-top: 1.5rem; color: var(--color-gold); display: none;"></p>
                    <p class="small-note text-center" style="margin-top: 1.5rem; opacity: 0.6;">
                        Tu mensaje será enviado de forma segura y recibirás una respuesta lo antes posible.
                    </p>
                </form>
            </div>
        </div>
    </section>

    <section class="section-padding reveal text-center">
        <div class="container">
            <h2 class="minimal-title">Servicios Disponibles en Valencia</h2>
            <div class="services-minimal-grid">
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-camera-retro"></i></div>
                    <h3>Sesiones de Fotos</h3>
                    <p>Retratos profesionales y branding personal en localizaciones exclusivas de Valencia.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-running"></i></div>
                    <h3>Eventos Deportivos</h3>
                    <p>Cobertura de competiciones y sesiones para deportistas de élite.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-briefcase"></i></div>
                    <h3>Eventos de Empresa</h3>
                    <p>Documentación de galas, congresos y jornadas corporativas.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    const contactForm = document.getElementById('contact-form');
    const formStatus = document.getElementById('form-status');

    contactForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const name = (document.getElementById('c-name') as HTMLInputElement).value;
        const phone = (document.getElementById('c-phone') as HTMLInputElement).value;
        const email = (document.getElementById('c-email') as HTMLInputElement).value;
        const subject_input = (document.getElementById('c-asunto') as HTMLInputElement).value;
        const message = (document.getElementById('c-mensaje') as HTMLTextAreaElement).value;
        const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;

        const formData = new FormData();
        formData.append('_subject', `Nuevo Proyecto: ${subject_input}`);
        formData.append('cliente_nombre', name);
        formData.append('cliente_email', email);
        formData.append('cliente_telefono', phone);
        formData.append('asunto', subject_input);
        formData.append('mensaje', message);

        if (formStatus) {
            formStatus.textContent = 'Enviando mensaje...';
            formStatus.style.display = 'block';
            formStatus.style.color = 'var(--color-gold)';
        }

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Enviando... <i class="fas fa-spinner fa-spin"></i>';
        }

        try {
            const response = await fetch("https://formspree.io/f/xkoyqbdj", {
                method: "POST",
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                if (formStatus) formStatus.textContent = '¡Mensaje enviado con éxito! Me pondré en contacto contigo pronto.';
                if (submitBtn) {
                    submitBtn.innerHTML = '¡Enviado! <i class="fas fa-check"></i>';
                    submitBtn.style.backgroundColor = '#28a745';
                    submitBtn.style.borderColor = '#28a745';
                }
                (contactForm as HTMLFormElement).reset();
            } else {
                throw new Error();
            }
        } catch (error) {
            if (formStatus) {
                formStatus.textContent = 'Error al enviar. Por favor, inténtalo de nuevo.';
                formStatus.style.color = '#ff6b6b';
            }
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Reintentar Envío <i class="fas fa-paper-plane"></i>';
            }
        }
    });
</script>

<style>
    .input-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 600px) {
        .input-grid-2 {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }

    .input-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .input-group label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 0.8rem;
        color: var(--color-text-light);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .input-group i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-gold);
        font-size: 0.9rem;
        opacity: 0.6;
        transition: all 0.3s ease;
        pointer-events: none;
        z-index: 2;
    }

    .input-group input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 1rem 1rem 3.5rem;
        color: #fff;
        font-family: inherit;
        border-radius: 8px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
        backdrop-filter: blur(10px);
    }

    .input-group input:focus {
        outline: none;
        border-color: var(--color-gold);
        background: rgba(197, 160, 89, 0.08);
        box-shadow: 0 0 30px rgba(197, 160, 89, 0.15);
    }

    .input-group:focus-within label {
        color: var(--color-gold);
        transform: translateX(5px);
    }

    .input-group:focus-within i {
        opacity: 1;
        transform: translateY(-50%) scale(1.1);
    }

    .contact-content-block {
        padding: 2rem 0;
    }
    
    .minimal-title {
        font-size: 1.8rem;
        letter-spacing: 2px;
        margin-bottom: 2rem;
        text-transform: uppercase;
        font-weight: 700;
        text-align: center;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: flex-start;
        gap: 4rem;
    }

    @media (max-width: 1050px) {
        .contact-grid {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .minimal-title {
            font-size: 1.3rem;
        }
    }
</style>
