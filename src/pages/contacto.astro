---
import Layout from '../layouts/Layout.astro';
import type { ImageMetadata } from 'astro';
import { contactInfo } from '../data/config';
import ContactForm from '../components/ContactForm.astro';

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>('../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });
const getImg = (path: string) => {
  const fullPath = `../assets/Fotos/${path}`;
  return galleryImages[fullPath]?.default;
};

const heroImg = getImg('hero-image.webp');
---

<Layout 
    title="Contactar Fotógrafo en Valencia - Reservas y Presupuestos" 
    description="¿Buscas un fotógrafo en Valencia? Contacta con JaviPhoto para reservar tu sesión de fotos o solicitar un presupuesto personalizado para tu proyecto o evento."
    activePage="contacto"
>
    <section class="services-hero contact-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">Reservar Fotógrafo en Valencia</h1>
            <p class="section-subtitle reveal hero-subtitle">¡Tu próximo gran proyecto comienza con un mensaje!</p>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Métodos de Contacto</h2>
            <div class="contact-methods-grid">
                <a href={`mailto:${contactInfo.email}`} class="contact-method-card gmail-social-card" data-mailto={contactInfo.email}>
                    <div class="method-icon"><i class="fas fa-envelope"></i></div>
                    <h3>Correo Electrónico</h3>
                    <p>{contactInfo.email}</p>
                    <span class="method-link">Enviar email <i class="fas fa-arrow-right"></i></span>
                </a>

                <a href={contactInfo.instagramUrl} target="_blank" rel="noopener noreferrer" class="contact-method-card" aria-label="Visitar mi perfil de Instagram">
                    <div class="method-icon"><i class="fab fa-instagram"></i></div>
                    <h3>Instagram</h3>
                    <p>@javier.fzr</p>
                    <span class="method-link">Ver perfil <i class="fas fa-arrow-right"></i></span>
                </a>

                <a href={contactInfo.whatsappUrl} target="_blank" rel="noopener noreferrer" class="contact-method-card" aria-label="Enviar mensaje por WhatsApp">
                    <div class="method-icon"><i class="fab fa-whatsapp"></i></div>
                    <h3>WhatsApp</h3>
                    <p>{contactInfo.formattedPhone}</p>
                    <span class="method-link">Escribir ahora <i class="fas fa-arrow-right"></i></span>
                </a>
            </div>
        </div>
    </section>

    <ContactForm 
        id="c"
        title="Presupuesto Personalizado"
        subtitle="¿Tu proyecto no encaja en los packs estándar? Cuéntame qué tienes en mente y diseñaré una propuesta a medida para ti."
        buttonText="Enviar Solicitud de Presupuesto"
        formSubjectPrefix="Nuevo Proyecto"
    />

    <section class="section-padding reveal">
        <div class="container">
            <div style="max-width: 900px; margin: 0 auto;">
                <h2 class="section-title text-center">¿Por qué elegir a JaviPhoto?</h2>
                <div class="editorial-body">
                    <p class="editorial-intro">Si estás buscando <strong>fotógrafos en Valencia</strong> que combinen técnica, creatividad y un estilo moderno, has llegado al lugar indicado. Me especializo en capturar momentos únicos, ya sea en eventos deportivos, corporativos o sesiones de marca personal.</p>
                    
                    <div class="why-choose-grid">
                        <div class="why-choose-card">
                            <i class="fas fa-bolt"></i>
                            <h4>Entrega Rápida</h4>
                            <p>Material optimizado y listo para usar en tiempo récord.</p>
                        </div>
                        <div class="why-choose-card">
                            <i class="fas fa-camera"></i>
                            <h4>Equipo Top</h4>
                            <p>Tecnología de última generación Sony Alpha para máxima calidad.</p>
                        </div>
                        <div class="why-choose-card">
                            <i class="fas fa-handshake"></i>
                            <h4>Trato Personal</h4>
                            <p>Presupuestos claros y adaptados 100% a tus necesidades.</p>
                        </div>
                    </div>

                    <p class="editorial-quote">"Cada disparo es una oportunidad para contar una historia que perdure."</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding reveal text-center">
        <div class="container">
            <h2 class="section-title">Servicios Disponibles en Valencia</h2>
            <div class="services-minimal-grid">
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-camera-retro"></i></div>
                    <h3>Sesiones de Fotos</h3>
                    <p>Retratos profesionales y branding personal en localizaciones exclusivas de Valencia.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-running"></i></div>
                    <h3>Eventos Deportivos</h3>
                    <p>Cobertura de competiciones y sesiones para deportistas de élite.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-briefcase"></i></div>
                    <h3>Eventos de Empresa</h3>
                    <p>Documentación de galas, congresos y jornadas corporativas.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>



<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .contact-hero {
        background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
        text-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }

    .hero-subtitle {
        color: white;
        font-size: 1.1rem;
        font-weight: 400;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .contact-form-section {
        background: var(--color-secondary);
    }

    .form-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }



    .full-width {
        width: 100%;
        margin-top: 1rem;
    }

    .editorial-intro {
        text-align: center;
        margin-bottom: 2rem;
        font-size: 1.1rem;
        opacity: 0.9;
    }

    .why-choose-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
    }

    .why-choose-card {
        background: rgba(255,255,255,0.03);
        padding: 2rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.05);
        text-align: center;
    }

    .why-choose-card i {
        color: var(--color-gold);
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .why-choose-card h4 {
        margin-bottom: 0.5rem;
        color: var(--color-gold);
    }

    .why-choose-card p {
        font-size: 0.9rem;
        opacity: 0.7;
    }

    .editorial-quote {
        text-align: center;
        margin-top: 3rem;
        font-style: italic;
        opacity: 0.8;
    }
    .contact-methods-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 2rem;
    }

    .contact-method-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2.5rem 2rem;
        border-radius: 12px;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
        aspect-ratio: 1/1;
    }

    .contact-method-card:hover {
        transform: translateY(-10px);
        background: rgba(197, 160, 89, 0.08);
        border-color: var(--color-gold);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .contact-method-card:active {
        transform: scale(0.95);
        background: rgba(197, 160, 89, 0.15);
        border-color: var(--color-gold);
    }

    .method-icon {
        width: 60px;
        height: 60px;
        background: rgba(197, 160, 89, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        color: var(--color-gold);
        font-size: 1.5rem;
        transition: all 0.4s ease;
    }

    .contact-method-card:hover .method-icon,
    .contact-method-card:active .method-icon {
        background: var(--color-gold);
        color: var(--color-secondary);
        transform: scale(1.1);
    }

    .contact-method-card h3 {
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .contact-method-card p {
        font-size: 0.95rem;
        opacity: 0.7;
        margin-bottom: 1.5rem;
    }

    .method-link {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-gold);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    @media (max-width: 992px) {
        .contact-methods-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
            width: 100%;
        }

        .contact-method-card {
            padding: 1.2rem 0.5rem;
            min-height: auto;
            border-radius: 12px;
            aspect-ratio: 1/1;
        }

        .contact-method-card h3,
        .contact-method-card p,
        .contact-method-card .method-link {
            display: none;
        }

        .method-icon {
            margin-bottom: 0;
            width: 60px;
            height: 60px;
            font-size: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .contact-methods-grid {
            gap: 0.8rem;
        }
        
        .method-icon {
            width: 55px;
            height: 55px;
            font-size: 1.3rem;
        }
    }



    .contact-content-block {
        padding: 2rem 0;
    }
    
    .contact-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: flex-start;
        gap: 4rem;
    }

    @media (max-width: 1050px) {
        .contact-grid {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .minimal-title {
            font-size: 1.3rem;
        }
    }
</style>
