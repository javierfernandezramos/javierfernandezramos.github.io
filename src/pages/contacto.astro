---
import Layout from '../layouts/Layout.astro';
import type { ImageMetadata } from 'astro';

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>('../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });
const getImg = (path: string) => {
  const fullPath = `../assets/Fotos/${path}`;
  return galleryImages[fullPath]?.default;
};

const heroImg = getImg('hero-image.webp');
---

<Layout 
    title="Contactar Fotógrafo en Valencia | Reservas y Presupuestos" 
    description="¿Buscas un fotógrafo en Valencia? Contacta con JaviPhoto para reservar tu sesión de fotos o solicitar un presupuesto personalizado para tu proyecto o evento."
    activePage="contacto"
>
    <section class="services-hero contact-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">Reservar Fotógrafo en Valencia</h1>
            <p class="section-subtitle reveal hero-subtitle">Tu próximo gran proyecto comienza con un mensaje.</p>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Métodos de Contacto</h2>
            <div class="contact-methods-grid">
                <a href="mailto:javierfernandezramos9@gmail.com" class="contact-method-card gmail-social-card" data-mailto="javierfernandezramos9@gmail.com">
                    <div class="method-icon"><i class="fas fa-envelope"></i></div>
                    <h3>Correo Electrónico</h3>
                    <p>javierfernandezramos9@gmail.com</p>
                    <span class="method-link">Enviar email <i class="fas fa-arrow-right"></i></span>
                </a>

                <a href="https://www.instagram.com/javier.fzr/" target="_blank" class="contact-method-card">
                    <div class="method-icon"><i class="fab fa-instagram"></i></div>
                    <h3>Instagram</h3>
                    <p>@javier.fzr</p>
                    <span class="method-link">Ver perfil <i class="fas fa-arrow-right"></i></span>
                </a>

                <a href="https://wa.me/34665018516" target="_blank" class="contact-method-card">
                    <div class="method-icon"><i class="fab fa-whatsapp"></i></div>
                    <h3>WhatsApp</h3>
                    <p>+34 665 018 516</p>
                    <span class="method-link">Escribir ahora <i class="fas fa-arrow-right"></i></span>
                </a>
            </div>
        </div>
    </section>

    <section id="formulario-contacto" class="section-padding reveal contact-form-section">
        <div class="container">
            <h2 class="section-title">Presupuesto Personalizado</h2>
            <p class="text-center form-subtitle">
                ¿Tu proyecto no encaja en los packs estándar? Cuéntame qué tienes en mente y diseñaré una propuesta a medida para ti.
            </p>
            
            <div class="calculator-card" style="max-width: 800px; margin: 0 auto;">
                <form id="contact-form" class="luxury-form">
                    <div class="input-grid-2">
                        <div class="input-group">
                            <label for="c-name">Nombre Completo</label>
                            <div style="position: relative;">
                                <i class="fas fa-user"></i>
                                <input type="text" id="c-name" name="name" placeholder="Tu nombre..." required />
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="c-phone">Teléfono</label>
                            <div style="position: relative;">
                                <i class="fas fa-phone"></i>
                                <input type="tel" id="c-phone" name="phone" placeholder="600 000 000..." required />
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="c-email">Correo Electrónico</label>
                        <div style="position: relative;">
                            <i class="fas fa-envelope"></i>
                            <input type="email" id="c-email" name="email" placeholder="tu@email.com..." required />
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="c-asunto">¿En qué puedo ayudarte?</label>
                        <div style="position: relative;">
                            <i class="fas fa-tag"></i>
                            <input type="text" id="c-asunto" name="asunto" placeholder="Ej: Reportaje para club, Evento corporativo..." required />
                        </div>
                    </div>

                        <div class="input-group">
                            <label for="c-mensaje">Detalles del Proyecto</label>
                            <div class="textarea-wrapper">
                                <i class="fas fa-comment-alt message-icon"></i>
                                <textarea id="c-mensaje" name="mensaje" placeholder="Cuéntame más sobre fechas, lugar y qué necesitas exactamente..." rows="5" required></textarea>
                            </div>
                        </div>

                    <button type="submit" class="btn submit-btn full-width">
                        Enviar Solicitud de Presupuesto <i class="fas fa-paper-plane"></i>
                    </button>
                    <p id="form-status" class="small-note text-center" style="margin-top: 1.5rem; color: var(--color-gold); display: none;"></p>
                    <p class="small-note text-center" style="margin-top: 1.5rem; opacity: 0.6;">
                        Tu mensaje será enviado de forma segura y recibirás una respuesta lo antes posible.
                    </p>
                </form>
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <div style="max-width: 900px; margin: 0 auto;">
                <h2 class="section-title text-center">¿Por qué elegir a JaviPhoto?</h2>
                <div class="editorial-body">
                    <p class="editorial-intro">Si estás buscando <strong>fotógrafos en Valencia</strong> que combinen técnica, creatividad y un estilo moderno, has llegado al lugar indicado. Me especializo en capturar momentos únicos, ya sea en eventos deportivos, corporativos o sesiones de marca personal.</p>
                    
                    <div class="why-choose-grid">
                        <div class="why-choose-card">
                            <i class="fas fa-bolt"></i>
                            <h4>Entrega Rápida</h4>
                            <p>Material optimizado y listo para usar en tiempo récord.</p>
                        </div>
                        <div class="why-choose-card">
                            <i class="fas fa-camera"></i>
                            <h4>Equipo Top</h4>
                            <p>Tecnología de última generación Sony Alpha para máxima calidad.</p>
                        </div>
                        <div class="why-choose-card">
                            <i class="fas fa-handshake"></i>
                            <h4>Trato Personal</h4>
                            <p>Presupuestos claros y adaptados 100% a tus necesidades.</p>
                        </div>
                    </div>

                    <p class="editorial-quote">"Cada disparo es una oportunidad para contar una historia que perdure."</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding reveal text-center">
        <div class="container">
            <h2 class="section-title">Servicios Disponibles en Valencia</h2>
            <div class="services-minimal-grid">
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-camera-retro"></i></div>
                    <h3>Sesiones de Fotos</h3>
                    <p>Retratos profesionales y branding personal en localizaciones exclusivas de Valencia.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-running"></i></div>
                    <h3>Eventos Deportivos</h3>
                    <p>Cobertura de competiciones y sesiones para deportistas de élite.</p>
                </div>
                <div class="service-item">
                    <div class="service-icon-box"><i class="fas fa-briefcase"></i></div>
                    <h3>Eventos de Empresa</h3>
                    <p>Documentación de galas, congresos y jornadas corporativas.</p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    const contactForm = document.getElementById('contact-form');
    const formStatus = document.getElementById('form-status');

    contactForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const name = (document.getElementById('c-name') as HTMLInputElement).value;
        const phone = (document.getElementById('c-phone') as HTMLInputElement).value;
        const email = (document.getElementById('c-email') as HTMLInputElement).value;
        const subject_input = (document.getElementById('c-asunto') as HTMLInputElement).value;
        const message = (document.getElementById('c-mensaje') as HTMLTextAreaElement).value;
        const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;

        const formData = new FormData();
        formData.append('_subject', `Nuevo Proyecto: ${subject_input}`);
        formData.append('cliente_nombre', name);
        formData.append('cliente_email', email);
        formData.append('cliente_telefono', phone);
        formData.append('asunto', subject_input);
        formData.append('mensaje', message);

        if (formStatus) {
            formStatus.textContent = 'Enviando mensaje...';
            formStatus.style.display = 'block';
            formStatus.style.color = 'var(--color-gold)';
        }

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Enviando... <i class="fas fa-spinner fa-spin"></i>';
        }

        try {
            const response = await fetch("https://formspree.io/f/xkoyqbdj", {
                method: "POST",
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                if (formStatus) formStatus.textContent = '¡Mensaje enviado con éxito! Me pondré en contacto contigo pronto.';
                if (submitBtn) {
                    submitBtn.innerHTML = '¡Enviado! <i class="fas fa-check"></i>';
                    submitBtn.style.backgroundColor = '#28a745';
                    submitBtn.style.borderColor = '#28a745';
                }
                (contactForm as HTMLFormElement).reset();
            } else {
                throw new Error();
            }
        } catch (error) {
            if (formStatus) {
                formStatus.textContent = 'Error al enviar. Por favor, inténtalo de nuevo.';
                formStatus.style.color = '#ff6b6b';
            }
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Reintentar Envío <i class="fas fa-paper-plane"></i>';
            }
        }
    });
</script>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .contact-hero {
        background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
        text-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }

    .hero-subtitle {
        color: white;
        font-size: 1.1rem;
        font-weight: 400;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .contact-form-section {
        background: var(--color-secondary);
    }

    .form-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }

    .textarea-wrapper {
        position: relative;
    }

    .message-icon {
        top: 20px !important;
        transform: none !important;
    }

    textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1.2rem 1rem 1.2rem 3.5rem;
        color: #fff;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        backdrop-filter: blur(10px);
        outline: none;
        resize: none;
    }

    .full-width {
        width: 100%;
        margin-top: 1rem;
    }

    .editorial-intro {
        text-align: center;
        margin-bottom: 2rem;
        font-size: 1.1rem;
        opacity: 0.9;
    }

    .why-choose-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
    }

    .why-choose-card {
        background: rgba(255,255,255,0.03);
        padding: 2rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.05);
        text-align: center;
    }

    .why-choose-card i {
        color: var(--color-gold);
        font-size: 2rem;
        margin-bottom: 1rem;
    }

    .why-choose-card h4 {
        margin-bottom: 0.5rem;
        color: var(--color-gold);
    }

    .why-choose-card p {
        font-size: 0.9rem;
        opacity: 0.7;
    }

    .editorial-quote {
        text-align: center;
        margin-top: 3rem;
        font-style: italic;
        opacity: 0.8;
    }
    .contact-methods-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 2rem;
    }

    .contact-method-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2.5rem 2rem;
        border-radius: 12px;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
        aspect-ratio: 1/1;
    }

    .contact-method-card:hover {
        transform: translateY(-10px);
        background: rgba(197, 160, 89, 0.08);
        border-color: var(--color-gold);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .contact-method-card:active {
        transform: scale(0.95);
        background: rgba(197, 160, 89, 0.15);
        border-color: var(--color-gold);
    }

    .method-icon {
        width: 60px;
        height: 60px;
        background: rgba(197, 160, 89, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        color: var(--color-gold);
        font-size: 1.5rem;
        transition: all 0.4s ease;
    }

    .contact-method-card:hover .method-icon,
    .contact-method-card:active .method-icon {
        background: var(--color-gold);
        color: var(--color-secondary);
        transform: scale(1.1);
    }

    .contact-method-card h3 {
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .contact-method-card p {
        font-size: 0.95rem;
        opacity: 0.7;
        margin-bottom: 1.5rem;
    }

    .method-link {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-gold);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    @media (max-width: 992px) {
        .contact-methods-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .contact-method-card {
            padding: 1.5rem 0.5rem;
            min-height: auto;
            border-radius: 12px;
            aspect-ratio: 1/1;
        }

        .contact-method-card h3,
        .contact-method-card p,
        .contact-method-card .method-link {
            display: none;
        }

        .method-icon {
            margin-bottom: 0;
            width: 70px;
            height: 70px;
            font-size: 1.8rem;
        }
    }

    .input-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 600px) {
        .input-grid-2 {
            grid-template-columns: 1fr;
            gap: 0;
        }
    }

    .input-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .input-group label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 0.8rem;
        color: var(--color-text-light);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .input-group i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-gold);
        font-size: 0.9rem;
        opacity: 0.6;
        transition: all 0.3s ease;
        pointer-events: none;
        z-index: 2;
    }

    .input-group input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 1rem 1rem 3.5rem;
        color: #fff;
        font-family: inherit;
        border-radius: 8px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
        backdrop-filter: blur(10px);
    }

    .input-group input:focus {
        outline: none;
        border-color: var(--color-gold);
        background: rgba(197, 160, 89, 0.08);
        box-shadow: 0 0 30px rgba(197, 160, 89, 0.15);
    }

    .input-group:focus-within label {
        color: var(--color-gold);
        transform: translateX(5px);
    }

    .input-group:focus-within i {
        opacity: 1;
        transform: translateY(-50%) scale(1.1);
    }

    .contact-content-block {
        padding: 2rem 0;
    }
    
    .contact-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: flex-start;
        gap: 4rem;
    }

    @media (max-width: 1050px) {
        .contact-grid {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .minimal-title {
            font-size: 1.3rem;
        }
    }
</style>
