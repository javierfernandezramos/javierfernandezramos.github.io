---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { contactInfo } from "../data/config";
import Testimonials from "../components/Testimonials.astro";
import ContactForm from "../components/ContactForm.astro";

// Import images from assets relative to src/pages/
const galleryImages = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/Fotos/**/*.{jpg,jpeg,png,webp}",
    {
        eager: true,
    },
);
const getImg = (path: string) => {
    const fullPath = `../assets/Fotos/${path}`;
    if (!galleryImages[fullPath]) {
        console.warn(`Imagen no encontrada: ${fullPath}`);
        return null;
    }
    return galleryImages[fullPath].default;
};

// Define hero & key images
const heroImg = getImg("hero-image.webp");
const portraitImg = getImg("Modelo/retrato-flex-form-f3.webp") || heroImg;
const photographerImg = getImg("photographer.webp") || heroImg;
const sportsImg = getImg("Deportes/1.webp") || heroImg;
const eventSportsImg = getImg("RicardoTormo31.webp") || heroImg;

const title = "Fotógrafo en Valencia - JaviPhoto";
const description =
    "¿Buscas un fotógrafo en Valencia especialista en deporte y fitness? Capturo la fuerza de tus entrenamientos y eventos con máxima fidelidad gráfica. ¡Reserva ya!";

const faqs = [
    {
        q: "¿Cuánto tiempo tardas en entregar las fotos?",
        a: "Normalmente entrego una selección previa en 48h y el pack completo editado en un plazo de 7 a 10 días laborables.",
    },
    {
        q: "¿En qué zonas de Valencia trabajas?",
        a: "Tengo disponibilidad en toda Valencia capital y localidades de la provincia (pabellones, playas, gimnasios o zonas de calistenia). Si el evento lo requiere, puedo desplazarme por la Comunidad Valenciana.",
    },
    {
        q: "¿Cómo se realiza la entrega del material?",
        a: "Todas las fotografías se entregan en alta resolución mediante una galería digital privada, editadas.",
    },
    {
        q: "¿Qué tipo de equipo utilizas para congelar el movimiento?",
        a: "Utilizo equipo profesional con ráfaga de alta velocidad y objetivos de gran apertura luminosa, lo que me permite trabajar en entornos oscuros como gimnasios sin perder nada de nitidez ni generar ruido digital molesto.",
    },
];

// JSON-LD Schemas
const siteUrl = "https://javiphoto.es";

const localBusinessSchema = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: "JaviPhoto - Javier Fernández Ramos Fotógrafo Valencia",
    image: `${siteUrl}/assets/Fotos/hero-image.webp`,
    "@id": `${siteUrl}/#localbusiness-valencia`,
    url: `${siteUrl}/fotografo-en-valencia`,
    telephone: contactInfo.phone,
    priceRange: "90€ - 350€",
    address: {
        "@type": "PostalAddress",
        addressLocality: "Valencia",
        addressRegion: "Valencia",
        postalCode: "46001",
        addressCountry: "ES",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 39.4699,
        longitude: -0.3763,
    },
    sameAs: [
        contactInfo.instagramUrl,
        contactInfo.tiktokUrl,
        "https://g.page/r/CfhBvKmELu39EBM",
    ],
};
---

<Layout title={title} description={description} activePage="servicios">
    <!-- JSON-LD Structured Data -->
    <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify(localBusinessSchema)}
    />
    <!-- JSON-LD FAQ Schema (Discontinued by Google, kept visual only) -->

    <!-- HERO SECTION -->
    <section class="services-hero valencia-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">
                Fotógrafo en Valencia - Deportes, Fitness, eventos y más
            </h1>
            <p class="section-subtitle reveal hero-subtitle">
                Muchos fotografos en valencia hacen fotos, pero yo capturo la
                intensidad de un movimiento, la fuerza de un levantamiento o la
                adrenalina de un evento. Eso requiere algo más que presionar un
                botón, hago que cada foto cuente una historia. Exige entender el
                esfuerzo detrás de cada atleta. Soy Javier Fernández, la mente
                detrás de <strong>JaviPhoto</strong>, y trabajo como <strong>fotógrafo en Valencia</strong> 
                ayudando a atletas, entrenadores, centros de fitness y organizadores
                de eventos a inmortalizar su rendimiento con imágenes que impactan.
            </p>
            <div class="hero-cta-box reveal">
                <a href="#contacto-landing" class="btn luxury-gallery-btn">Reserva tu Sesión <i class="fas fa-calendar-alt"></i></a>
            </div>
        </div>
    </section>

    <!-- SERVICIOS DE FOTOGRAFÍA -->
    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">
                Servicios de Fotografía Profesional en Valencia
            </h2>
            <p class="text-center tariffs-subtitle"> Como fotógrafo en valencia, adapto mi equipo y mi técnica a lavelocidad y exigencia de cada disciplina:</p>

            <div class="services-detail-grid">
                <!-- Fitness y Marca Personal -->
                <div class="service-detail-card reveal">
                    <div class="service-detail-img-wrapper">
                        {
                            portraitImg && (
                                <Image
                                    src={portraitImg}
                                    alt="Fotografía fitness en un gimnasio de Valencia por JaviPhoto"
                                    width={500}
                                    class="service-detail-img"
                                />
                            )
                        }
                    </div>
                    <div class="service-detail-content">
                        <h3>Fotografía Fitness y de Marca Personal</h3>
                        <p>
                            Lleva tu marca al siguiente nivel. Realizo sesiones
                            de fotos en gimnasios, boxes de CrossFit o
                            exteriores en Valencia para creadores de contenido,
                            entrenadores personales y atletas que necesitan un
                            porfolio profesional y estético.
                        </p>
                        <a
                            href="/servicios/fotografo-fitness-valencia"
                            class="btn-text-gold"
                            >Saber más sobre fitness <i
                                class="fas fa-arrow-right"></i></a
                        >
                    </div>
                </div>

                <!-- Deportiva de Alta Velocidad -->
                <div class="service-detail-card reveal">
                    <div class="service-detail-img-wrapper">
                        {
                            sportsImg && (
                                <Image
                                    src={sportsImg}
                                    alt="Fotógrafo deportivo de alta velocidad en Valencia"
                                    width={500}
                                    class="service-detail-img"
                                />
                            )
                        }
                    </div>
                    <div class="service-detail-content">
                        <h3>Fotografía Deportiva en Valencia</h3>
                        <p>
                            Especialista en congelar el tiempo en disciplinas de
                            fuerza, atletismo y deportes de equipo. Capturo el
                            momento exacto del esfuerzo máximo con una nitidez
                            técnica impecable.
                        </p>
                        <a
                            href="/servicios/fotografo-deportivo-valencia"
                            class="btn-text-gold"
                            >Saber más sobre deporte <i
                                class="fas fa-arrow-right"></i></a
                        >
                    </div>
                </div>

                <!-- Cobertura de Eventos y Competiciones -->
                <div class="service-detail-card reveal">
                    <div class="service-detail-img-wrapper">
                        {
                            eventSportsImg && (
                                <Image
                                    src={eventSportsImg}
                                    alt="Cobertura de eventos y competiciones en Valencia"
                                    width={500}
                                    class="service-detail-img"
                                />
                            )
                        }
                    </div>
                    <div class="service-detail-content">
                        <h3>Fotografía de eventos Valencia</h3>
                        <p>
                            Desde competiciones locales en la Comunidad
                            Valenciana hasta eventos corporativos o deportivos
                            de gran escala. Cobertura completa con entrega
                            rápida de material optimizado para prensa y redes
                            sociales.
                        </p>
                        <a
                            href="/servicios/fotografo-eventos-valencia"
                            class="btn-text-gold">Saber más sobre eventos <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <!-- Otros servicios adicionales para cubrir búsquedas secundarias -->
            <div class="other-services-row text-center reveal">
                <p class="small-text-heading">También realizo:</p>
                <div class="other-services-badges">
                    <a
                        href="/servicios/retratos-profesionales-valencia"
                        class="service-badge"
                        ><i class="fas fa-user-tie"></i> Retratos Profesionales</a
                    >
                    <a href="/servicios/fotografia-marca-personal-valencia"class="service-badge"><i class="fas fa-briefcase"></i> Marca Personal y Branding</a>
                </div>
            </div>
        </div>
    </section>

    <!-- PORTFOLIO / GALERÍA -->
    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Mi Galería de Trabajos</h2>
            <p class="text-center tariffs-subtitle">
                Una pequeña muestra de trabajos realizados. <a href="/galeria">Ver Todos</a>
            </p>

            <div class="gallery-grid">
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Novios/3.webp")?.src}
                >
                    {
                        getImg("Novios/3.webp") && (
                            <Image
                                src={getImg("Novios/3.webp")!}
                                alt="Fotografía de boda en la Ciudad de las Artes, Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Bodas</span
                        >
                    </div>
                </div>
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Modelo/retrato-flex-form-f3.webp")?.src}
                >
                    {
                        getImg("Modelo/retrato-flex-form-f3.webp") && (
                            <Image
                                src={
                                    getImg("Modelo/retrato-flex-form-f3.webp")!
                                }
                                alt="Retrato profesional en las calles del centro de Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Retratos</span
                        >
                    </div>
                </div>
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Eventos/3.webp")?.src}
                >
                    {
                        getImg("Eventos/3.webp") && (
                            <Image
                                src={getImg("Eventos/3.webp")!}
                                alt="Reportaje fotográfico de evento corporativo en el Carmen, Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Eventos</span
                        >
                    </div>
                </div>
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Novios/5.webp")?.src}
                >
                    {
                        getImg("Novios/5.webp") && (
                            <Image
                                src={getImg("Novios/5.webp")!}
                                alt="Sesión fotográfica de pareja al atardecer en la Albufera de Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Exteriores</span
                        >
                    </div>
                </div>
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Deportes/1.webp")?.src}
                >
                    {
                        getImg("Deportes/1.webp") && (
                            <Image
                                src={getImg("Deportes/1.webp")!}
                                alt="Fotografía de acción deportiva de atletismo en Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Deportes</span
                        >
                    </div>
                </div>
                <div
                    class="gallery-item reveal active"
                    data-src={getImg("Marca/2.webp")?.src}
                >
                    {
                        getImg("Marca/2.webp") && (
                            <Image
                                src={getImg("Marca/2.webp")!}
                                alt="Sesión de fotos de marca personal para profesional en Valencia"
                                width={600}
                            />
                        )
                    }
                    <div class="overlay">
                        <span
                            ><i class="fa-solid fa-magnifying-glass"></i> Marca Personal</span
                        >
                    </div>
                </div>
            </div>

            <div class="text-center reveal" style="margin-top: 2rem;">
                <a href="/galeria" class="btn luxury-gallery-btn">Ver Galería Completa <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </section>

    <!-- PHILOSOPHY SECTION -->
    <section class="section-padding reveal secondary-bg eeat-section">
        <div class="container eeat-grid">
            <div class="eeat-text">
                <div class="acerca-profile-wrapper">
                    <div class="acerca-mobile-profile">
                        {
                            photographerImg && (
                                <Image
                                    src={photographerImg}
                                    alt="Javier Fernández Ramos"
                                    width={300}
                                    height={300}
                                    class="photographer-main-img loaded profile-img-rounded"
                                />
                            )
                        }
                    </div>
                    <a
                        target="_blank"
                        href="https://www.instagram.com/javier.fzr/"
                        class="instagram-profile-icon"
                        aria-label="Visitar Instagram de Javier Fernández Ramos"
                    >
                        <i class="fab fa-instagram"></i>
                    </a>
                </div>
                <h2>Fidelidad Gráfica y Acción: Mi Filosofía de Trabajo</h2>
                <div class="editorial-body">
                    <p class="lead-text">
                        El mercado está lleno de imágenes con filtros excesivos
                        que distorsionan la realidad. En <strong
                            >JaviPhoto</strong
                        > apuesto por una filosofía clara: <strong
                            >máxima fidelidad gráfica</strong
                        >.
                    </p>
                    <p>
                        Busco que cada fotografía sea un reflejo real representando los sentimientos del momento, 
                        respetando los colores, las texturas y la iluminación natural del entorno.
                    </p>
                    <blockquote>
                        "Mi objetivo no es solo tomar una foto bonita, es hacer que esa foto despúes de editada sea real y no una distorsión 
                        siempre cumpliendo con los requisitos  que el cliente."
                    </blockquote>
                    <p>
                        Trabajo con equipos profesionales y programas de edición para corregir imperfecciones.
                        Esto me permite garantizar imágenes nítidas, contrastadas y listas para webs, porfolio o redes sociales.
                    </p>
                </div>

                <div class="eeat-badges">
                    <div class="eeat-badge-card">
                        <i class="fas fa-camera"></i>
                        <span>Sony Alpha</span>
                    </div>
                    <div class="eeat-badge-card">
                        <i class="fas fa-map-location-dot"></i>
                        <span>Basado en Valencia</span>
                    </div>
                    <div class="eeat-badge-card">
                        <i class="fas fa-award"></i>
                        <span>24-48h</span>
                    </div>
                </div>
            </div>
            <div class="eeat-img-box glass-frame">
                {
                    photographerImg && (
                        <Image
                            src={photographerImg}
                            alt="Javier Fernández Ramos, fotógrafo en Valencia"
                            width={800}
                            class="eeat-img"
                        />
                    )
                }
            </div>
        </div>
    </section>

    <!-- GARANTÍA E-E-A-T -->
    <section class="section-padding reveal eeat-pillars-section">
        <div class="container">
            <h2 class="section-title">
                Garantía: Por qué Elegir a JaviPhoto
            </h2>
            <p class="text-center tariffs-subtitle">
                A la hora de contratar un <strong
                    >fotógrafo profesional en Valencia</strong
                >, la confianza y la experiencia sobre el terreno lo son todo.
                Mi enfoque de trabajo se apoya en tres pilares:
            </p>

            <div class="eeat-pillars-grid">
                <div class="pillar-card reveal">
                    <div class="pillar-icon-wrapper">
                        <i class="fas fa-running"></i>
                    </div>
                    <h3>Experiencia Real</h3>
                    <p>
                        Conozco desde dentro las dinámicas del entrenamiento o de eventos, siempre estoy preparado para disparar.
                    </p>
                </div>
                <div class="pillar-card reveal">
                    <div class="pillar-icon-wrapper">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3>Conocimiento Técnico</h3>
                    <p>
                        Utilizo configuraciones avanzadas de obturación y
                        enfoque de última tecnología para asegurar que ninguna
                        foto salga movida, sin importar la velocidad de la
                        acción.
                    </p>
                </div>
                
                <div class="pillar-card reveal">
                    <div class="pillar-icon-wrapper">
                        <i class="fas fa-map-location-dot"></i>
                    </div>
                    <h3>Compromiso Local</h3>
                    <p>
                        Como fotógrafo basado en Valencia, ofrezco total
                        flexibilidad para desplazarme a cualquier instalación
                        o complejo.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIOS -->
    <Testimonials title="Opiniones de Atletas y Clientes" showGoogleButton={true} />

    <!-- PREGUNTAS FRECUENTES (FAQs) -->
    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">
                Preguntas Frecuentes: Servicios Fotografía
            </h2>
            <p class="text-center tariffs-subtitle">
                Resuelvo tus dudas principales antes de planificar tu sesión
                fotográfica.
            </p>

            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item faq-item-interactive">
                            <div class="faq-question-bar">
                                <h3 class="faq-sub-q">{faq.q}</h3>
                                <i class="fas fa-plus toggle-icon" />
                            </div>
                            <div class="faq-answer-block">
                                <p>{faq.a}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- CONTACTO Y RESERVAS -->
    <ContactForm 
        id="landing"
        title="¿Hablamos? Reserva tu Sesión de Fotos en valencia hoy mismo"
        subtitle="Solicita disponibilidad sin compromiso. Escríbeme y diseñemos juntos un reportaje a tu medida."
        buttonText="Enviar Solicitud de Reserva"
        formSubjectPrefix="Reserva Landing Valencia"
    />
</Layout>

<script>
    // Accordion interaction logic
    document.querySelectorAll(".faq-item-interactive").forEach((item) => {
        const questionBar = item.querySelector(".faq-question-bar");
        questionBar?.addEventListener("click", () => {
            item.classList.toggle("active");
        });
    });
</script>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .valencia-hero {
        background-image:
            linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
            var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding-top: 150px;
    }

    .hero-title {
        color: white;
        margin-bottom: 1.5rem;
        font-size: 2.4rem;
        line-height: 1.25;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-subtitle {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1.25rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-cta-box {
        margin-top: 2rem;
    }

    .intro-paragraph {
        font-size: 1.15rem;
        line-height: 1.8;
        max-width: 900px;
        margin: 0 auto;
        color: var(--color-text-light);
    }

    .intro-paragraph strong {
        color: #fff;
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Grid de Especialidades de Servicios */
    .services-detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 2.5rem;
        margin-bottom: 4rem;
    }

    .service-detail-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        overflow: hidden;
        transition: all 0.4s ease;
    }

    .service-detail-card:hover {
        border-color: var(--color-gold);
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.04);
    }

    .service-detail-img-wrapper {
        height: 250px;
        overflow: hidden;
    }

    .service-detail-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .service-detail-card:hover .service-detail-img {
        transform: scale(1.05);
    }

    .service-detail-content {
        padding: 2rem;
    }

    .service-detail-content h3 {
        color: #fff;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .service-detail-content p {
        font-size: 0.95rem;
        color: var(--color-text-light);
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .btn-text-gold {
        color: var(--color-gold);
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition:
            transform 0.3s ease,
            color 0.3s ease;
    }

    .btn-text-gold:hover {
        color: #fff;
        transform: translateX(5px);
    }

    /* Fila de otros servicios */
    .other-services-row {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 3rem;
        margin-top: 2rem;
    }

    .small-text-heading {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--color-text-light);
        margin-bottom: 1.5rem;
    }

    .other-services-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    .service-badge {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.8rem 1.5rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text-light);
        transition: all 0.3s ease;
    }

    .service-badge i {
        color: var(--color-gold);
        margin-right: 8px;
    }

    .service-badge:hover {
        border-color: var(--color-gold);
        background: rgba(197, 160, 89, 0.08);
        color: #fff;
        transform: translateY(-2px);
    }

    /* EEAT Section Styles */
    .eeat-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 4rem;
        align-items: center;
    }

    .eeat-text h2 {
        font-size: 2.2rem;
        margin-bottom: 2rem;
        line-height: 1.2;
    }

    .eeat-text .editorial-body {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--color-text-light);
    }

    .eeat-text .editorial-body p {
        margin-bottom: 1.5rem;
    }

    .eeat-text .editorial-body strong {
