---
import Layout from "../../layouts/Layout.astro";
import PricingPacks from "../../components/PricingPacks.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../../assets/Fotos/${path}`;
    return galleryImages[fullPath]?.default;
};

const title = "Fotógrafo de Eventos en Valencia";
const description =
    "Cobertura profesional de eventos en Valencia. Fotografía para congresos, fiestas corporativas y celebraciones sociales con una visión técnica y elegante.";
const heroImg = getImg("Eventos/1.webp");

const features = [
    {
        icon: "fas fa-film",
        title: "Aftermovie Corporativo",
        text: "Video resumen de 1-3 minutos que captura la esencia y energía de tu evento.",
    },
    {
        icon: "fas fa-mobile-alt",
        title: "Contenido Vertical",
        text: "Clips rápidos y entrevistas cortas listos para publicar en redes sociales.",
    },
    {
        icon: "fas fa-broadcast-tower",
        title: "Cobertura B-Roll",
        text: "Grabación de recursos en alta calidad para futuros vídeos promocionales.",
    },
];

const faqs = [
    {
        q: "¿Qué tendencias en fotografía de eventos veremos en 2026?",
        a: 'La tendencia principal es la autenticidad: menos fotos posadas y más "documentary style". El uso de iluminación natural y la entrega rápida son fundamentales.',
    },
    {
        q: "¿Realizas vídeos para eventos de empresa en Valencia?",
        a: "Sí, ofrezco servicios combinados de fotografía y vídeo para que tengas una cobertura completa y coherente de tu evento.",
    },
    {
        q: "¿Te desplazas por toda la Comunidad Valenciana?",
        a: "Principalmente trabajo en Valencia capital, pero realizo reportajes en toda la provincia y alrededores según las necesidades.",
    },
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero subpage-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">{title}</h1>
            <p class="section-subtitle reveal hero-subtitle">
                {description}
            </p>
        </div>
    </section>

    <section id="tarifas" class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Packs y Tarifas</h2>
            <p class="text-center tariffs-subtitle">
                Selecciona el pack que mejor se adapte a tu evento.
            </p>
            <PricingPacks serviceId="eventos" />
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Servicios Opcionales de Vídeo</h2>
            <div class="services-minimal-grid">
                {
                    features.map((feature) => (
                        <div class="service-item">
                            <div class="service-icon-box">
                                <i class={feature.icon} />
                            </div>
                            <h3>{feature.title}</h3>
                            <p>{feature.text}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item">
                            <h3 class="faq-sub-q">{faq.q}</h3>
                            <p>{faq.a}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding seo-content-section reveal secondary-bg">
        <div class="container">
            <div class="seo-content-inner">
                <h2>¿Por qué contratar un fotógrafo de eventos en Valencia?</h2>
                <p>Organizar un congreso, una inauguración, un evento de <em>team building</em> o una feria requiere meses de planificación, esfuerzo y presupuesto. Como <strong>fotógrafo de eventos profesional en Valencia</strong>, mi responsabilidad es que ese esfuerzo quede documentado para siempre con imágenes de la más alta calidad, listas para ser utilizadas en tu próxima campaña de marketing, dossier de prensa o comunicación interna.</p>
                <p>Valencia se ha convertido en un hub europeo clave para la organización de eventos corporativos, con recintos espectaculares como Feria Valencia, el Palacio de Congresos o la Ciudad de las Artes y las Ciencias. Conozco estos espacios y sé cómo aprovechar la luz arquitectónica, lidiar con los complicados contrastes lumínicos de los escenarios y capturar el ambiente real del evento sin interrumpir el flujo natural de los asistentes.</p>
                <h3>Fotografía documental corporativa: discreción y calidad</h3>
                <p>Mi estilo fotográfico en eventos se centra en el fotoperiodismo corporativo: capturar momentos de networking genuino, expresiones de los ponentes en plena acción, reacciones del público y detalles del <em>setup</em> (branding, iluminación, catering) de manera totalmente discreta. Busco documentar la verdadera energía y profesionalidad de la ocasión huyendo de los posados artificiales.</p>
                <p>Además, ofrezco la opción de combinar el reportaje fotográfico con la creación de un <strong>aftermovie en vídeo</strong>. Este servicio es ideal para resumir la jornada en clips cortos y dinámicos (1-2 minutos) de alto impacto visual, perfectos para compartir en LinkedIn, Instagram o la web de tu empresa, atrayendo a patrocinadores y nuevos asistentes para tus futuras ediciones.</p>
            </div>
        </div>
    </section>

    <section class="section-padding reveal related-services-section">
        <div class="container text-center">
            <h2 class="section-title">Otros servicios que podrían interesarte</h2>
            <div class="related-links-grid">
                <a href="/servicios/fotografia-marca-personal-valencia" class="related-link-card">Marca Personal</a>
                <a href="/servicios/retratos-profesionales-valencia" class="related-link-card">Retratos Profesionales</a>
                <a href="/servicios/fotografo-deportivo-valencia" class="related-link-card">Fotografía Deportiva</a>
                <a href="/servicios/fotografo-fitness-valencia" class="related-link-card">Fotografía Fitness</a>
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Planeando un evento?</h2>
            <p class="cta-subtitle">Asegúrate un reportaje profesional que destaque los valores de tu marca.</p>
            <a href="/contacto" class="btn luxury-gallery-btn"
                >Solicitar Presupuesto <i class="fas fa-paper-plane"></i></a
            >
        </div>
    </section>
</Layout>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .subpage-hero {
        background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.2rem;
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .faq-container-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-sub-item {
        margin-bottom: 2rem;
    }

    .faq-sub-q {
        color: var(--color-gold);
    }

    .cta-subtitle {
        margin-bottom: 2rem;
    }
</style>
