---
import Layout from "../../layouts/Layout.astro";
import PricingPacks from "../../components/PricingPacks.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../../assets/Fotos/${path}`;
    return galleryImages[fullPath]?.default;
};

const title = "Fotógrafo Fitness en Valencia";
const description =
    "Fotografía fitness profesional en Valencia. Capturo tu esfuerzo, dedicación y progreso físico con un estilo visual potente y motivador.";
const heroImg = getImg("Modelo/f3-fit-modelo.webp");
const mainImg = getImg("Modelo/fitness-leggins.webp");

const features = [
    {
        icon: "fas fa-dumbbell",
        title: "Sesiones en Gimnasio",
        text: "Captura tu entrenamiento real con iluminación profesional en tu centro deportivo.",
    },
    {
        icon: "fas fa-bolt",
        title: "Edición High-End",
        text: "Retoque avanzado que resalta la definición muscular y la estética deportiva.",
    },
    {
        icon: "fas fa-mobile-alt",
        title: "Contenido para Reels",
        text: "Video clips dinámicos de tus mejores series para potenciar tu marca personal.",
    },
];

const faqs = [
    {
        q: "¿Dónde se realizan las sesiones de fotos fitness?",
        a: "Podemos realizarlas en tu gimnasio habitual (previa autorización), en centros colaboradores en Valencia o en exteriores si buscas un estilo más lifestyle.",
    },
    {
        q: "¿Necesito experiencia posando?",
        a: "Para nada. Te guiaré en cada postura para resaltar tus puntos fuertes y conseguir ese ángulo que mejor muestre tu condición física.",
    },
    {
        q: "¿Qué ropa debo llevar?",
        a: "Recomiendo traer varios conjuntos de ropa deportiva que te hagan sentir cómodo y seguro. Los colores sólidos suelen funcionar mejor en cámara.",
    },
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero subpage-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">{title}</h1>
            <p class="section-subtitle reveal hero-subtitle">
                {description}
            </p>
        </div>
    </section>

    <section id="tarifas" class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Packs y Tarifas</h2>
            <p class="text-center tariffs-subtitle">
                Elige el nivel de cobertura que necesitas para tu portfolio fitness.
            </p>
            <PricingPacks serviceId="fitness" />
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Servicios Especializados</h2>
            <div class="services-minimal-grid">
                {
                    features.map((feature) => (
                        <div class="service-item">
                            <div class="service-icon-box">
                                <i class={feature.icon} />
                            </div>
                            <h3>{feature.title}</h3>
                            <p>{feature.text}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item">
                            <h3 class="faq-sub-q">{faq.q}</h3>
                            <p>{faq.a}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding seo-content-section reveal secondary-bg">
        <div class="container">
            <div class="seo-content-inner">
                <h2>¿Por qué contratar un fotógrafo fitness en Valencia?</h2>
                <p>En el mundo del fitness y el culturismo, la imagen lo es todo. Como <strong>fotógrafo fitness profesional en Valencia</strong>, entiendo perfectamente la dedicación, las horas de entrenamiento y la estricta dieta que hay detrás de cada físico. Mi objetivo es traducir todo ese esfuerzo y disciplina en imágenes de alto impacto visual que reflejen tu mejor versión y documenten tu progreso de forma estética y profesional.</p>
                <p>Ya seas un entrenador personal buscando mejorar su marca personal, un atleta preparándose para una competición, o simplemente alguien orgulloso de su transformación física tras meses de sacrificio, una sesión de fotos profesional marcará la diferencia en tus redes sociales y portfolio. En Valencia contamos con gimnasios espectaculares, ubicaciones urbanas increíbles y zonas al aire libre perfectas para sesiones de fotos fitness tanto en interiores con iluminación controlada como en exteriores aprovechando la luz natural.</p>
                <h3>Iluminación y Técnicas para Fotografía de Gimnasio</h3>
                <p>La clave de unas fotografías de gimnasio espectaculares reside en el dominio de la iluminación. Utilizo esquemas de luces profesionales, flashes de estudio y modificadores específicos para esculpir el cuerpo mediante luces y sombras. Esta técnica resalta al máximo la definición muscular, el bombeo, la vascularidad y las proporciones anatómicas, logrando ese aspecto tridimensional, épico y motivador que ves en las portadas de las revistas especializadas en fitness y culturismo.</p>
                <p>Además, te guiaré durante toda la sesión: desde el <em>pumping</em> previo necesario para congestionar el músculo hasta las poses exactas para que tu físico luzca en su punto máximo de tensión, simetría y estética. No necesitas tener experiencia previa posando frente a la cámara; mi trabajo como fotógrafo deportivo y fitness es dirigir cada disparo, corregir tu postura y asegurar resultados perfectos que te harán sentir orgulloso de tu trabajo en el gimnasio.</p>
            </div>
        </div>
    </section>

    <section class="section-padding reveal related-services-section">
        <div class="container text-center">
            <h2 class="section-title">Otros servicios que podrían interesarte</h2>
            <div class="related-links-grid">
                <a href="/servicios/retratos-profesionales-valencia" class="related-link-card">Retratos Profesionales</a>
                <a href="/servicios/fotografia-marca-personal-valencia" class="related-link-card">Marca Personal</a>
                <a href="/servicios/fotografo-deportivo-valencia" class="related-link-card">Fotografía Deportiva</a>
                <a href="/servicios/fotografo-eventos-valencia" class="related-link-card">Eventos</a>
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Listo para el siguiente nivel?</h2>
            <p class="cta-subtitle">Reserva tu sesión ahora y muestra el resultado de tu disciplina.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Sesión <i class="fas fa-calendar-check"></i></a>
        </div>
    </section>
</Layout>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .subpage-hero {
        background-image: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.2rem;
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .faq-container-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-sub-item {
        margin-bottom: 2rem;
    }

    .faq-sub-q {
        color: var(--color-gold);
    }

    .cta-subtitle {
        margin-bottom: 2rem;
    }
</style>
