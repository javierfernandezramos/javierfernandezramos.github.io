---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });
const getImg = (path: string) => {
  const fullPath = `../../assets/Fotos/${path}`;
  return galleryImages[fullPath]?.default;
};

const title = 'Retratos Profesionales en Valencia | Fotografía de Retrato';
const description = 'Sesiones de retrato profesional en Valencia. Mejora tu imagen personal o profesional con retratos limpios, directos y de alta calidad técnica.';
const heroImg = getImg('Modelo/5.webp');
const mainTitle = 'Impacto Visual Profesional';
const mainText = 'Un retrato profesional en Valencia es más que una simple fotografía; es tu carta de presentación al mundo. Me especializo en capturar la esencia de cada profesional, resaltando su liderazgo y cercanía.';
const mainImg = getImg('Modelo/4.webp');

const features = [
  { icon: 'fab fa-linkedin', title: 'Fotos para LinkedIn', text: 'Retratos optimizados para destacar en la red profesional más importante del mundo.' },
  { icon: 'fas fa-id-badge', title: 'Perfiles Corporativos', text: 'Sesiones para equipos directivos y empleados con una estética coherente.' },
  { icon: 'fas fa-user-check', title: 'Branding Personal', text: 'Retratos que van más allá del busto, mostrando tu entorno de trabajo y personalidad.' }
];

const faqs = [
  { q: '¿Cómo posar para fotos de negocios?', a: 'No te preocupes por eso. Durante la sesión, te guiaré paso a paso para que proyectes seguridad y naturalidad.' },
  { q: '¿Dónde se realizan las sesiones de retratos en Valencia?', a: 'Podemos realizarlas en estudio, en tu oficina o en localizaciones exteriores seleccionadas en el centro de Valencia.' },
  { q: '¿Cómo puedo reservar mi sesión de fotos de branding en Valencia?', a: 'Es muy sencillo. Solo tienes que contactarme a través del formulario indicando qué tipo de perfil necesitas.' }
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('${heroImg?.src}'); background-size: cover; background-position: center; min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center;`}>
        <div class="container">
            <h1 class="section-title reveal" style="color: white; margin-bottom: 1rem;">{title}</h1>
            <p class="section-subtitle reveal" style="color: rgba(255,255,255,0.9); font-size: 1.2rem;">{description}</p>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <div class="acerca-grid">
                <div class="acerca-text">
                    <h2 class="main-title">{mainTitle}</h2>
                    <div class="editorial-body">
                        <p>{mainText}</p>
                    </div>
                </div>
                <div class="acerca-img glass-frame">
                    <Image src={mainImg} alt={title} width={600} class="loaded" />
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding bg-accent reveal" style="background: var(--color-accent);">
        <div class="container">
            <h2 class="section-title">Servicios Incluidos</h2>
            <div class="services-minimal-grid">
                {features.map((feature) => (
                    <div class="service-item">
                        <div class="service-icon-box"><i class={feature.icon}></i></div>
                        <h3>{feature.title}</h3>
                        <p>{feature.text}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div style="max-width: 800px; margin: 0 auto;">
                {faqs.map((faq) => (
                    <div style="margin-bottom: 2rem;">
                        <h3 style="color: var(--color-gold);">{faq.q}</h3>
                        <p>{faq.a}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Es hora de actualizar tu imagen?</h2>
            <p style="margin-bottom: 2rem;">Consigue los mejores retratos profesionales en Valencia hoy mismo.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Sesión <i class="fas fa-user-tie"></i></a>
        </div>
    </section>
</Layout>
