---
import Layout from "../../layouts/Layout.astro";
import PricingPacks from "../../components/PricingPacks.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../../assets/Fotos/${path}`;
    return galleryImages[fullPath]?.default;
};

const title = "Retratos Profesionales en Valencia";
const description =
    "Sesiones de retrato profesional en Valencia. Mejora tu imagen personal o profesional con retratos limpios, directos y de alta calidad técnica.";
const heroImg = getImg("Modelo/2.webp");

const features = [
    {
        icon: "fas fa-video",
        title: "Video Retrato",
        text: "Clips cinematográficos breves que capturan tu personalidad en movimiento.",
    },
    {
        icon: "fas fa-user-circle",
        title: "Video Intro",
        text: "Una breve presentación profesional para tu web o perfil de LinkedIn.",
    },
    {
        icon: "fas fa-camera-retro",
        title: "Behind the Scenes",
        text: "Video del proceso de la sesión para generar contenido en tus redes sociales.",
    },
];

const faqs = [
    {
        q: "¿Cómo posar para fotos de negocios?",
        a: "No te preocupes por eso. Durante la sesión, te guiaré paso a paso para que proyectes seguridad y naturalidad.",
    },
    {
        q: "¿Dónde se realizan las sesiones de retratos en Valencia?",
        a: "Podemos realizarlas en estudio, en tu oficina o en localizaciones exteriores seleccionadas en el centro de Valencia.",
    },
    {
        q: "¿Cómo puedo reservar mi sesión de fotos de branding en Valencia?",
        a: "Es muy sencillo. Solo tienes que contactarme a través del formulario indicando qué tipo de perfil necesitas.",
    },
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero subpage-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">{title}</h1>
            <p class="section-subtitle reveal hero-subtitle">
                {description}
            </p>
        </div>
    </section>

    <section id="tarifas" class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Packs y Tarifas</h2>
            <p class="text-center tariffs-subtitle">
                Selecciona el pack que mejor se adapte a tu nivel y necesidades.
            </p>
            <PricingPacks serviceId="retratos" />
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Servicios Opcionales de Vídeo</h2>
            <div class="services-minimal-grid">
                {
                    features.map((feature) => (
                        <div class="service-item">
                            <div class="service-icon-box">
                                <i class={feature.icon} />
                            </div>
                            <h3>{feature.title}</h3>
                            <p>{feature.text}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item">
                            <h3 class="faq-sub-q">{faq.q}</h3>
                            <p>{faq.a}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding seo-content-section reveal secondary-bg">
        <div class="container">
            <div class="seo-content-inner">
                <h2>La importancia de un buen retrato profesional en Valencia</h2>
                <p>Tu rostro es la primera impresión que tienen de ti tus clientes, empleadores o socios comerciales. Un selfie con el móvil o una foto recortada de unas vacaciones ya no son suficientes en el mercado actual. Como <strong>fotógrafo especializado en retratos en Valencia</strong>, me dedico a crear imágenes que proyecten profesionalidad, seguridad y cercanía, factores clave para destacar en LinkedIn, en la página "Sobre mí" de tu web corporativa o en tu currículum.</p>
                <p>El retrato profesional ha evolucionado. Atrás quedaron las sonrisas forzadas y los fondos grises planos y aburridos. Mi objetivo es capturar tu verdadera esencia. En mi estudio, en tus oficinas o en localizaciones de Valencia, trabajaremos juntos para encontrar el estilo fotográfico que mejor se adapte a tu sector: desde retratos corporativos tradicionales para ejecutivos y abogados, hasta retratos creativos y <em>lifestyle</em> para artistas, freelancers y emprendedores digitales.</p>
                <h3>Técnica fotográfica: luz, dirección y retoque High-End</h3>
                <p>La diferencia entre una foto común y un retrato excepcional es la iluminación y la dirección de arte. Utilizo técnicas de iluminación de estudio avanzadas para resaltar tus mejores rasgos, suavizar imperfecciones de forma natural y crear un ambiente visual que hable por ti. Durante el <em>shooting</em>, te guiaré paso a paso con las poses y la expresión facial, asegurando que te relajes y muestres tu actitud más genuina.</p>
                <p>Una vez terminada la sesión, aplico un proceso de retoque <em>High-End</em> (alta gama). Esto significa que edito cada fotografía con máxima precisión: limpieza de la piel respetando su textura natural, ajuste de colorimetría para dar un aspecto <em>premium</em> y optimización para los formatos exigidos por las redes sociales o medios impresos. El resultado es un retrato impecable, listo para elevar tu perfil profesional al instante.</p>
            </div>
        </div>
    </section>

    <section class="section-padding reveal related-services-section">
        <div class="container text-center">
            <h2 class="section-title">Otros servicios que podrían interesarte</h2>
            <div class="related-links-grid">
                <a href="/servicios/fotografia-marca-personal-valencia" class="related-link-card">Marca Personal</a>
                <a href="/servicios/fotografo-fitness-valencia" class="related-link-card">Fotografía Fitness</a>
                <a href="/servicios/fotografo-deportivo-valencia" class="related-link-card">Fotografía Deportiva</a>
                <a href="/servicios/fotografo-eventos-valencia" class="related-link-card">Eventos Corporativos</a>
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Es hora de actualizar tu imagen?</h2>
            <p class="cta-subtitle">Solicita un presupuesto sin compromiso para tu sesión en Valencia.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Sesión <i class="fas fa-user-tie"></i></a>
        </div>
    </section>
</Layout>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .subpage-hero {
        background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.2rem;
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .faq-container-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-sub-item {
        margin-bottom: 2rem;
    }

    .faq-sub-q {
        color: var(--color-gold);
    }

    .cta-subtitle {
        margin-bottom: 2rem;
    }
</style>
