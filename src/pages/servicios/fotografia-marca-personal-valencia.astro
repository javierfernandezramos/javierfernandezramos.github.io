---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/Fotos/**/*.{jpg,jpeg,png,webp}', { eager: true });
const getImg = (path: string) => {
  const fullPath = `../../assets/Fotos/${path}`;
  return galleryImages[fullPath]?.default;
};

const title = 'Fotografía de Marca Personal en Valencia | Branding Visual';
const description = 'Potencia tu marca personal en Valencia con fotografía profesional. Imágenes que comunican tus valores y profesionalidad para web y redes sociales.';
const heroImg = getImg('Marca/3.webp');
const mainTitle = 'Tu Imagen es tu Marca';
const mainText = 'En el mundo digital actual, la fotografía de marca personal en Valencia es una herramienta esencial para emprendedores. Me especializo en crear sesiones que transmiten confianza y profesionalismo.';
const mainImg = getImg('cubas-31.webp');

const features = [
  { icon: 'fas fa-camera', title: 'Shooting de Marca Personal', text: 'Sesiones dinámicas en localizaciones estratégicas para mostrar tu faceta más profesional.' },
  { icon: 'fas fa-hashtag', title: 'Contenido para RRSS', text: 'Imágenes diseñadas específicamente para Instagram, LinkedIn y otras plataformas.' },
  { icon: 'fas fa-box-open', title: 'Foto de Producto', text: 'Captura de tus productos con una estética de branding que enamora a tus clientes.' }
];

const faqs = [
  { q: '¿Qué ideas para fotos de marca personal recomiendas?', a: 'Recomiendo combinar retratos corporativos con fotos en acción y lifestyle que muestre tu personalidad.' },
  { q: '¿Cuál es el presupuesto para una fotografía de marca personal?', a: 'El presupuesto varía según la duración de la sesión. Ofrezco packs personalizados para emprendedores.' },
  { q: '¿Me ayudas a elegir el vestuario y la localización?', a: '¡Por supuesto! Realizamos una asesoría previa para definir el estilo y los mejores lugares de Valencia.' }
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero" style={`background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('${heroImg?.src}'); background-size: cover; background-position: center; min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center;`}>
        <div class="container">
            <h1 class="section-title reveal" style="color: white; margin-bottom: 1rem;">{title}</h1>
            <p class="section-subtitle reveal" style="color: rgba(255,255,255,0.9); font-size: 1.2rem;">{description}</p>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <div class="acerca-grid">
                <div class="acerca-text">
                    <h2 class="main-title">{mainTitle}</h2>
                    <div class="editorial-body">
                        <p>{mainText}</p>
                    </div>
                </div>
                <div class="acerca-img glass-frame">
                    <Image src={mainImg} alt={title} width={600} class="loaded" />
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding bg-accent reveal" style="background: var(--color-accent);">
        <div class="container">
            <h2 class="section-title">Servicios de Branding</h2>
            <div class="services-minimal-grid">
                {features.map((feature) => (
                    <div class="service-item">
                        <div class="service-icon-box"><i class={feature.icon}></i></div>
                        <h3>{feature.title}</h3>
                        <p>{feature.text}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div style="max-width: 800px; margin: 0 auto;">
                {faqs.map((faq) => (
                    <div style="margin-bottom: 2rem;">
                        <h3 style="color: var(--color-gold);">{faq.q}</h3>
                        <p>{faq.a}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Listo para elevar tu marca?</h2>
            <p style="margin-bottom: 2rem;">Hagamos que tu primera impresión sea inolvidable.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Shooting <i class="fas fa-camera"></i></a>
        </div>
    </section>
</Layout>
