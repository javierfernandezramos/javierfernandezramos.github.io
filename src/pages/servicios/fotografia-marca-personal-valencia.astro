---
import Layout from "../../layouts/Layout.astro";
import PricingPacks from "../../components/PricingPacks.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../../assets/Fotos/${path}`;
    return galleryImages[fullPath]?.default;
};

const title = "Fotografía de Marca Personal en Valencia";
const description =
    "Potencia tu marca personal en Valencia con fotografía profesional. Imágenes que comunican tus valores y profesionalidad para web y redes sociales.";
const heroImg = getImg("Marca/3.webp");

const features = [
    {
        icon: "fas fa-video",
        title: "Brand Story Video",
        text: "Crea una conexión profunda con tu audiencia a través de un vídeo narrativo de marca.",
    },
    {
        icon: "fas fa-box-open",
        title: "Producto en Movimiento",
        text: "Videos cinematográficos que destacan los detalles y beneficios de tus productos.",
    },
    {
        icon: "fas fa-play-circle",
        title: "Contenido para YouTube/IG",
        text: "Producción de vídeos educativos, tutoriales o charlas para tu estrategia de contenido.",
    },
];

const faqs = [
    {
        q: "¿Qué ideas para fotos de marca personal recomiendas?",
        a: "Recomiendo combinar retratos corporativos con fotos en acción y lifestyle que muestre tu personalidad.",
    },
    {
        q: "¿Cuál es el presupuesto para una fotografía de marca personal?",
        a: "El presupuesto varía según la duración de la sesión. Ofrezco packs personalizados para emprendedores.",
    },
    {
        q: "¿Me ayudas a elegir el vestuario y la localización?",
        a: "¡Por supuesto! Realizamos una asesoría previa para definir el estilo y los mejores lugares de Valencia.",
    },
];
---

<Layout title={title} description={description} activePage="servicios">
    <section class="services-hero subpage-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">{title}</h1>
            <p class="section-subtitle reveal hero-subtitle">
                {description}
            </p>
        </div>
    </section>

    <section id="tarifas" class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Packs y Tarifas</h2>
            <p class="text-center tariffs-subtitle">
                Selecciona el pack que mejor se adapte a tu nivel y necesidades.
            </p>
            <PricingPacks serviceId="branding" />
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Servicios Opcionales de Vídeo</h2>
            <div class="services-minimal-grid">
                {
                    features.map((feature) => (
                        <div class="service-item">
                            <div class="service-icon-box">
                                <i class={feature.icon} />
                            </div>
                            <h3>{feature.title}</h3>
                            <p>{feature.text}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item">
                            <h3 class="faq-sub-q">{faq.q}</h3>
                            <p>{faq.a}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding seo-content-section reveal secondary-bg">
        <div class="container">
            <div class="seo-content-inner">
                <h2>¿Por qué necesitas fotografía de marca personal en Valencia?</h2>
                <p>En el panorama digital actual, tu imagen es tu carta de presentación más poderosa. Como <strong>fotógrafo de marca personal en Valencia</strong>, mi trabajo es ayudarte a transmitir confianza, autoridad y cercanía a través de imágenes profesionales que conecten directamente con tu cliente ideal. Ya seas un CEO, emprendedor, consultor o creativo, una buena fotografía corporativa es una inversión directa en tu negocio.</p>
                <p>No se trata de los clásicos y aburridos retratos sobre un fondo blanco. La fotografía de <em>Personal Branding</em> moderna documenta quién eres y cómo trabajas. En Valencia disponemos de una luz mediterránea perfecta y multitud de localizaciones ideales: desde modernos espacios de coworking y oficinas, hasta cafeterías de diseño o la icónica arquitectura de la ciudad para transmitir un aire más vanguardista e innovador.</p>
                <h3>Diferénciate de la competencia con imágenes profesionales</h3>
                <p>Una sesión de marca personal debe contar tu historia. Durante nuestro <em>shooting</em> corporativo, capturaremos retratos limpios para tu perfil de LinkedIn y página web, así como fotos "lifestyle" y en acción (trabajando, en reuniones, creando tu producto) que podrás usar durante meses en tu estrategia de contenidos, redes sociales, newsletters y campañas publicitarias.</p>
                <p>Mi enfoque es natural y muy guiado. Sé que ponerte delante de una cámara puede resultar intimidante, por lo que crearemos un ambiente relajado donde te sientas cómodo. Nos aseguraremos de que el vestuario, la iluminación y las localizaciones estén perfectamente alineados con los valores y la paleta de colores de tu empresa, generando un material visual coherente y altamente profesional.</p>
            </div>
        </div>
    </section>

    <section class="section-padding reveal related-services-section">
        <div class="container text-center">
            <h2 class="section-title">Otros servicios que podrían interesarte</h2>
            <div class="related-links-grid">
                <a href="/servicios/fotografo-fitness-valencia" class="related-link-card">Fotografía Fitness</a>
                <a href="/servicios/retratos-profesionales-valencia" class="related-link-card">Retratos Profesionales</a>
                <a href="/servicios/fotografo-deportivo-valencia" class="related-link-card">Fotografía Deportiva</a>
                <a href="/servicios/fotografo-eventos-valencia" class="related-link-card">Eventos Corporativos</a>
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Listo para elevar tu marca?</h2>
            <p class="cta-subtitle">Solicita un presupuesto sin compromiso para tu sesión en Valencia.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Shooting <i class="fas fa-camera"></i></a>
        </div>
    </section>
</Layout>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .subpage-hero {
        background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.2rem;
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .faq-container-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-sub-item {
        margin-bottom: 2rem;
    }

    .faq-sub-q {
        color: var(--color-gold);
    }

    .cta-subtitle {
        margin-bottom: 2rem;
    }
</style>
