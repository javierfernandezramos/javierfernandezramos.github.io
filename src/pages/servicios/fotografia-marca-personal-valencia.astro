---
import Layout from "../../layouts/Layout.astro";
import PricingPacks from "../../components/PricingPacks.astro";
import type { ImageMetadata } from "astro";

// Import images
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../../assets/Fotos/${path}`;
    return galleryImages[fullPath]?.default;
};

const title = "Fotógrafo de Marca Personal en Valencia - Sesiones de Branding";
const description =
    "Fotografía de marca personal y branding en Valencia para emprendedores y coaches. Consigue contenido estratégico para un mes de redes sociales y web. Desde 90€.";
const subtitle = "Consigue contenido estratégico para un mes de redes sociales. Precios claros desde 90 €.";
const heroImg = getImg("Marca/3.webp");

const features = [
    {
        icon: "fas fa-video",
        title: "Brand Story Video",
        text: "Crea una conexión profunda con tu audiencia a través de un vídeo narrativo de marca.",
    },
    {
        icon: "fas fa-box-open",
        title: "Producto en Movimiento",
        text: "Videos cinematográficos que destacan los detalles y beneficios de tus productos.",
    },
    {
        icon: "fas fa-play-circle",
        title: "Contenido para YouTube/IG",
        text: "Producción de vídeos educativos, tutoriales o charlas para tu estrategia de contenido.",
    },
];

const faqs = [
    {
        q: "¿Cuánto cuesta un fotógrafo de marca personal en Valencia?",
        a: "El pack básico Quick Start cuesta entre 90 €-110 € (15 fotos). El pack intermedio Brand Story cuesta entre 200 €-240 € (contenido para 1 mes de redes). El pack premium Total Identity empieza desde 350 €.",
    },
    {
        q: "¿Cuántas fotos necesito para mi estrategia de redes sociales?",
        a: "Para un perfil activo en Instagram o LinkedIn que publica 3 veces por semana, unas 15-20 fotos al mes son ideales. Nuestro pack Brand Story cubre exactamente esa necesidad.",
    },
    {
        q: "¿Cuál es la diferencia entre retrato corporativo y marca personal?",
        a: "El retrato corporativo es una foto de perfil formal de tu rostro. La marca personal abarca además fotos lifestyle, en acción y de detalle que muestran tu personalidad y tu método de trabajo.",
    },
    {
        q: "¿El pack de marca personal incluye vídeo o reels?",
        a: "Sí, nuestro pack premium Total Identity incluye un vídeo presentación de 30 segundos y el pack intermedio viene con planificación de contenido visual de regalo.",
    },
    {
        q: "¿Entregas las fotos sin editar (RAW)?",
        a: "No. La edición es el 50% de nuestra firma visual. Solo entregamos las tomas seleccionadas con revelado profesional y retoque digital de alta calidad.",
    },
];
---

<Layout title={title} description={description} activePage="servicios">
    <!-- JSON-LD FAQ Schema (Discontinued by Google, kept visual only) -->

    <section class="services-hero subpage-hero">
        <div class="container">
            <h1 class="section-title reveal hero-title">Fotógrafo de Marca Personal en Valencia - Sesión de Fotos de Branding para Emprendedores y Coaches</h1>
            <p class="section-subtitle reveal hero-subtitle">
                {subtitle}
            </p>
        </div>
    </section>

    <section class="section-padding reveal seo-content-section">
        <div class="container">
            <div class="seo-content-inner text-center-desktop">
                <h2>Fotografía de Branding: comunica tus valores y atrae más clientes</h2>
                <p>
                    Detrás de cada proyecto exitoso hay una gran historia y una persona con valores definidos. Las fotografías de stock genéricas y los contenidos improvisados con el móvil ya no conectan con tu cliente ideal. Como fotógrafo de marca personal en Valencia, te ayudo a crear una identidad visual coherente y profesional. Hacemos retratos corporativos modernos, fotos en acción y estilo lifestyle diseñados estratégicamente para nutrir tu web, LinkedIn e Instagram durante meses, logrando diferenciarte de la competencia y aumentar tus ventas de manera directa.
                </p>
            </div>
        </div>
    </section>

    <section id="tarifas" class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Packs y Tarifas de Marca Personal y Branding</h2>
            <p class="text-center tariffs-subtitle">Selecciona el pack que mejor se adapte a tu nivel y necesidades.</p>
            <PricingPacks serviceId="branding" />
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <h2 class="section-title">Servicios Opcionales de Vídeo para Branding</h2>
            <div class="services-minimal-grid">
                {
                    features.map((feature) => (
                        <div class="service-item">
                            <div class="service-icon-box">
                                <i class={feature.icon} />
                            </div>
                            <h3>{feature.title}</h3>
                            <p>{feature.text}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <div class="seo-content-inner">
                <h2>Áreas de Aplicación de la Fotografía de Marca</h2>
                <p>Diseñamos cada sesión según las necesidades de comunicación y marketing de tu negocio:</p>
                <div class="disciplines-grid">
                    <div class="discipline-card">
                        <i class="fas fa-mug-hot"></i>
                        <h3>Retratos Lifestyle en Acción</h3>
                        <p>Imágenes naturales y dinámicas de ti trabajando en tu espacio de coworking, cafetería o despacho habitual en Valencia.</p>
                    </div>
                    <div class="discipline-card">
                        <i class="fas fa-laptop-code"></i>
                        <h3>Identidad Visual Corporativa</h3>
                        <p>Fotografías corporativas elegantes para tu sitio web, cabeceras profesionales de redes y dosieres comerciales.</p>
                    </div>
                    <div class="discipline-card">
                        <i class="fas fa-comments"></i>
                        <h3>Sesiones para Coaches y Consultores</h3>
                        <p>Imágenes que transmiten empatía, cercanía, autoridad y dinamismo para conectar emocionalmente con tus asesorados.</p>
                    </div>
                    <div class="discipline-card">
                        <i class="fas fa-calendar-check"></i>
                        <h3>Contenido Mensual Estratégico</h3>
                        <p>Banco de imágenes ordenado y listo para tus publicaciones e historias semanales en Instagram y LinkedIn.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container">
            <div class="seo-content-inner">
                <h2>¿Cómo funciona una sesión de marca personal en Valencia?</h2>
                <div class="process-steps">
                    <div class="step-item">
                        <span class="step-number">01</span>
                        <h3>1. Sesión estratégica de identidad visual</h3>
                        <p>Antes de pulsar el obturador, planificamos qué quieres transmitir, qué colores representan tu identidad visual y definimos la dirección artística.</p>
                    </div>
                    <div class="step-item">
                        <span class="step-number">02</span>
                        <h3>2. Selección de localizaciones y outfits</h3>
                        <p>Elegimos los lugares idóneos en Valencia (coworkings, oficinas de diseño, exteriores arquitectónicos) y coordinamos las mudas de vestuario.</p>
                    </div>
                    <div class="step-item">
                        <span class="step-number">03</span>
                        <h3>3. Shooting y dirección en la sesión</h3>
                        <p>Realizamos la sesión de fotos de forma dinámica, divertida y sin agobios. Te guiaré en todo momento para que transmitas tu esencia con total naturalidad.</p>
                    </div>
                    <div class="step-item">
                        <span class="step-number">04</span>
                        <h3>4. Selección en 48h y entrega final</h3>
                        <p>En menos de 48 horas seleccionas tus tomas favoritas desde tu galería privada, y en 7-10 días laborables te entrego el material final completamente editado.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Para quién es la fotografía de marca personal</h2>
            <div class="for-whom-grid">
                <div class="for-whom-card">
                    <h3>Para emprendedores y profesionales autónomos</h3>
                    <p>Consigue imágenes que muestren tu personalidad, tu método de trabajo y el valor diferencial de tu marca frente a grandes competidores.</p>
                </div>
                <div class="for-whom-card">
                    <h3>Para coaches, consultores y mentores</h3>
                    <p>La confianza es la clave de tus ventas. Muestra tu profesionalidad con retratos cercanos, nítidos y auténticos que abran nuevas oportunidades.</p>
                </div>
                <div class="for-whom-card">
                    <h3>Para creadores de contenido e influencers</h3>
                    <p>Contenido visual de altísima calidad y coherencia estética para mantener tus redes sociales (Instagram, TikTok) activas e inspiradoras.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding reveal">
        <div class="container text-center">
            <h2 class="section-title">Opiniones sobre mis sesiones de branding</h2>
            <div class="featured-testimonial">
                <div class="testimonial-stars">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                </div>
                <p class="testimonial-text">
                    "Muy satisfecho, es un chaval de 10, llegó puntual a la ubicación e hizo un trabajo espectacular. Está muy poco reconocido la verdad, agradecido con haberle encontrado."
                </p>
                <span class="testimonial-author">- Angel Lopez Palao, cliente de marca personal en Valencia</span>
            </div>
            <div class="testimonials-link-box">
                <a href="/#testimonios" class="btn luxury-gallery-btn">Ver todas las opiniones en la página de inicio <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </section>

    <section class="section-padding reveal secondary-bg">
        <div class="container">
            <h2 class="section-title">Preguntas frecuentes sobre marca personal en Valencia</h2>
            <div class="faq-container-narrow">
                {
                    faqs.map((faq) => (
                        <div class="faq-sub-item">
                            <h3 class="faq-sub-q">{faq.q}</h3>
                            <p>{faq.a}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section-padding reveal related-services-section">
        <div class="container text-center">
            <h2 class="section-title">Otros servicios que podrían interesarte</h2>
            <div class="related-links-grid">
                <a href="/servicios/retratos-profesionales-valencia" class="related-link-card">Retratos Profesionales</a>
                <a href="/servicios/fotografo-fitness-valencia" class="related-link-card">Fotografía Fitness</a>
                <a href="/servicios/fotografo-deportivo-valencia" class="related-link-card">Fotografía Deportiva</a>
                <a href="/servicios/fotografo-eventos-valencia" class="related-link-card">Eventos Corporativos</a>
            </div>
        </div>
    </section>

    <section id="cta-servicios" class="section-padding">
        <div class="container text-center reveal">
            <h2>¿Listo para elevar tu marca personal en Valencia?</h2>
            <p class="cta-subtitle">Reservas sin compromiso. Asegura tu fecha con una señal del 25% del total.</p>
            <a href="/contacto" class="btn luxury-gallery-btn">Reservar Shooting <i class="fas fa-calendar-check"></i></a>
        </div>
    </section>
</Layout>

<style define:vars={{ heroUrl: `url('${heroImg?.src}')` }}>
    .subpage-hero {
        background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), var(--heroUrl);
        background-size: cover;
        background-position: center;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .hero-title {
        color: white;
        margin-bottom: 1rem;
        font-size: 2.2rem;
        line-height: 1.2;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.2rem;
    }

    .tariffs-subtitle {
        margin-bottom: 3rem;
        color: var(--color-text-light);
    }

    .secondary-bg {
        background: var(--color-secondary);
    }

    .faq-container-narrow {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-sub-item {
        margin-bottom: 2rem;
    }

    .faq-sub-q {
        color: var(--color-gold);
        font-size: 1.15rem;
        margin-bottom: 0.5rem;
    }

    .cta-subtitle {
        margin-bottom: 2rem;
    }

    .disciplines-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-top: 2rem;
    }

    @media (max-width: 768px) {
        .disciplines-grid {
            gap: 1rem;
        }
        .discipline-card {
            padding: 1.5rem 1.25rem !important;
        }
    }

    @media (min-width: 769px) {
        .disciplines-grid .discipline-card:last-child:nth-child(odd) {
            grid-column: span 2;
        }
    }

    .discipline-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 3rem 2.5rem;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    .discipline-card:hover {
        border-color: var(--color-gold);
        background: rgba(255, 255, 255, 0.04);
        transform: translateY(-3px);
    }

    .discipline-card i {
        font-size: 2.5rem;
        color: var(--color-gold);
        margin-bottom: 1.25rem;
    }

    .discipline-card h3 {
        font-size: 1.3rem;
        margin-bottom: 0.75rem;
        color: #fff;
    }

    .discipline-card p {
        font-size: 0.95rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }

    .process-steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }

    .step-item {
        position: relative;
        padding-top: 1.5rem;
    }

    .step-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: rgba(197, 160, 89, 0.15);
        position: absolute;
        top: -1rem;
        left: 0;
        font-family: 'Outfit', sans-serif;
    }

    .step-item h3 {
        font-size: 1.15rem;
        color: #fff;
        margin-bottom: 0.75rem;
        position: relative;
        z-index: 1;
    }

    .step-item p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }

    .for-whom-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
    }

    .for-whom-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2rem;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    .for-whom-card:hover {
        border-color: var(--color-gold);
    }

    .for-whom-card h3 {
        font-size: 1.15rem;
        color: var(--color-gold);
        margin-bottom: 0.75rem;
    }

    .for-whom-card p {
        font-size: 0.9rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }

    .featured-testimonial {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        border: 1px solid rgba(197, 160, 89, 0.2);
        background: rgba(255, 255, 255, 0.01);
        position: relative;
    }

    .testimonial-stars {
        color: var(--color-gold);
        margin-bottom: 1rem;
    }

    .testimonial-text {
        font-size: 1.1rem;
        font-style: italic;
        color: #fff;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .testimonial-author {
        color: var(--color-gold);
        font-weight: 700;
        font-size: 0.95rem;
    }

    .testimonials-link-box {
        margin-top: 1.5rem;
    }
</style>
