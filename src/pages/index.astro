---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Import fixed images
import photographerImg from "../assets/Fotos/photographer.webp";
import heroImg from "../assets/Fotos/hero-image.webp";

// Import gallery images for the "Featured Gallery" section
const galleryImages = import.meta.glob<{ default: ImageMetadata }>("../assets/Fotos/**/*.{jpg,jpeg,png,webp}", {
    eager: true,
});
const getImg = (path: string) => {
    const fullPath = `../assets/Fotos/${path}`;
    if (!galleryImages[fullPath]) {
        console.warn(`Imagen no encontrada: ${fullPath}`);
        return null;
    }
    return galleryImages[fullPath].default;
};
---

<Layout
    title="JaviPhoto | Fotógrafo en Valencia - Retratos, Eventos y Deportes"
    description="Javier Fernández Ramos, fotógrafo profesional en Valencia. Especializado en retratos, eventos corporativos, deportes y marca personal. Capturando la esencia de cada momento."
    activePage="inicio"
    preloadImage={heroImg.src}>
    <section id="hero" class="hero-section" style={`--hero-url: url('${heroImg.src}')`}>
        <div class="hero-content">
            <h1 class="reveal">Javier Photography <span class="sr-only">| Fotógrafo en Valencia</span></h1>
            <p class="reveal">
                "Capturando la esencia de momentos fugaces." <br />
                <a href="/contacto">Contáctame <i class="fa-solid fa-right-to-bracket"></i></a>
            </p>
            <a href="#galeria" class="btn reveal">Ver Más <i class="fas fa-arrow-down"></i></a>
        </div>
    </section>

    <section id="acerca" class="section-padding">
        <div class="container acerca-grid reveal">
            <div class="acerca-text">
                <div class="acerca-profile-wrapper">
                    <div class="acerca-mobile-profile">
                        <Image
                            src={photographerImg}
                            alt="Javier Fernández Ramos"
                            width={300}
                            height={300}
                            class="photographer-main-img loaded"
                            style="object-fit: cover; border-radius: 50%;"
                        />
                    </div>
                    <a
                        target="_blank"
                        href="https://www.instagram.com/javier.fzr/"
                        class="instagram-profile-icon"
                        aria-label="Visitar Instagram de Javier Fernández Ramos">
                        <i class="fab fa-instagram"></i>
                    </a>
                </div>
                <h2 class="section-title main-title">El Arte de lo Esencial</h2>
                <div class="editorial-body">
                    <p>
                        Javier Fernández Ramos <a href="https://www.instagram.com/javier.fzr/">@javier.fzr</a>,
                        fotógrafo profesional en Valencia. Me especializo en capturar la realidad desde una perspectiva
                        limpia y directa, buscando siempre la fidelidad en cada imagen.
                    </p>
                    <p>
                        Mi trabajo se define por la atención al detalle y la capacidad de capturar las cosas de la
                        manera que las quieres ver. Con experiencia en retratos, eventos y deportes, ofrezco una visión
                        técnica y profesional para cada proyecto.
                    </p>
                </div>
                <div class="contact-links-luxury">
                    <a href="#" class="luxury-cta-link">Cuéntame tu visión →</a>
                </div>
            </div>
            <div class="acerca-img glass-frame reveal">
                <Image src={photographerImg} alt="Retrato del fotógrafo" width={800} />
            </div>
        </div>
    </section>

    <section id="galeria" class="section-padding">
        <div class="container reveal">
            <h2 class="section-title" id="galeriaDestacada">Galería Destacada</h2>
            <div class="gallery-grid">
                <div class="gallery-item reveal active" data-src={getImg("Modelo/retrato-flex-form-f3.webp")?.src}>
                    <Image
                        src={getImg("Modelo/retrato-flex-form-f3.webp") || heroImg}
                        alt="Retrato minimalista"
                        width={600}
                        class="loaded"
                        data-src={getImg("Modelo/retrato-flex-form-f3.webp")?.src}
                    />
                    <div class="overlay"><span>Retrato</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("playa-sunset-99.webp")?.src}>
                    <Image
                        src={getImg("playa-sunset-99.webp") || heroImg}
                        alt="Novios en la playa"
                        width={600}
                        data-src={getImg("playa-sunset-99.webp")?.src}
                    />
                    <div class="overlay"><span>Novios</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("Modelo/fitness-leggins.webp")?.src}>
                    <Image
                        src={getImg("Modelo/fitness-leggins.webp") || heroImg}
                        alt="Fotografía Blanco y Negro"
                        width={600}
                        data-src={getImg("Modelo/fitness-leggins.webp")?.src}
                    />
                    <div class="overlay"><span>B&W</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("RicardoTormo31.webp")?.src}>
                    <Image
                        src={getImg("RicardoTormo31.webp") || heroImg}
                        alt="Fotografía de Coches"
                        width={600}
                        data-src={getImg("RicardoTormo31.webp")?.src}
                    />
                    <div class="overlay"><span>Coches</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("rio.webp")?.src}>
                    <Image
                        src={getImg("rio.webp") || heroImg}
                        alt="Momentos Espontáneos"
                        width={600}
                        data-src={getImg("rio.webp")?.src}
                    />
                    <div class="overlay"><span>Momentos Fugazes</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("novios1.webp")?.src}>
                    <Image
                        src={getImg("novios1.webp") || heroImg}
                        alt="Sesión de Novios"
                        width={600}
                        data-src={getImg("novios1.webp")?.src}
                    />
                    <div class="overlay"><span>Novios</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("Modelo/DSC01142.webp")?.src}>
                    <Image
                        src={getImg("Modelo/DSC01142.webp") || heroImg}
                        alt="Lifestyle y Retrato"
                        width={600}
                        data-src={getImg("Modelo/DSC01142.webp")?.src}
                    />
                    <div class="overlay"><span>FITNESS</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("Fruteria036.webp")?.src}>
                    <Image
                        src={getImg("Fruteria036.webp") || heroImg}
                        alt="Fotografía de Negocios"
                        width={600}
                        data-src={getImg("Fruteria036.webp")?.src}
                    />
                </div>
                <div class="gallery-item reveal active" data-src={getImg("cubas-31.webp")?.src}>
                    <Image
                        src={getImg("cubas-31.webp") || heroImg}
                        alt="Fotografía de Marca"
                        width={600}
                        data-src={getImg("cubas-31.webp")?.src}
                    />
                    <div class="overlay"><span>Marca</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("porsche.webp")?.src}>
                    <Image
                        src={getImg("porsche.webp") || heroImg}
                        alt="Porsche Lifestyle"
                        width={600}
                        data-src={getImg("porsche.webp")?.src}
                    />
                    <div class="overlay"><span>COCHES</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("Deportes/1.webp")?.src}>
                    <Image
                        src={getImg("Deportes/1.webp") || heroImg}
                        alt="Fotografía de Deportes"
                        width={600}
                        data-src={getImg("Deportes/1.webp")?.src}
                    />
                    <div class="overlay"><span>DEPORTES</span></div>
                </div>
                <div class="gallery-item reveal active" data-src={getImg("Modelo/2.webp")?.src}>
                    <Image
                        src={getImg("Modelo/2.webp") || heroImg}
                        alt="Retrato Editorial"
                        width={600}
                        data-src={getImg("Modelo/2.webp")?.src}
                    />
                    <div class="overlay"><span>Lifestyle</span></div>
                </div>
            </div>
            <div class="gallery-floating-container">
                <a href="/galeria" class="btn luxury-gallery-btn"
                    >Ver Galería Completa <i class="fas fa-arrow-right"></i></a
                >
            </div>
        </div>
    </section>

    <section id="packs" class="section-padding" style="background: var(--color-secondary);">
        <div class="container reveal">
            <h2 class="section-title">Packs de Fotografía</h2>
            <p class="text-center" style="margin-bottom: 4rem; color: var(--color-text-light); max-width: 700px; margin-left: auto; margin-right: auto;">
                Selección de servicios premium para capturar tu mejor versión. Descubre nuestras tarifas por categoría.
            </p>
            
            <div class="packs-categories-grid">
                <!-- Deportes -->
                <div class="pack-category-card reveal">
                    <div class="category-icon"><i class="fas fa-running"></i></div>
                    <h3>Deportes</h3>
                    <p>45 fotos brutales para lucir en Instagram.</p>
                    <a href="/servicios/fotografo-deportivo-valencia#tarifas" class="pack-preview-info-btn">
                        <span class="pack-name-preview">Full Performance</span>
                        <span class="pack-price-preview">Desde 160€</span>
                    </a>
                </div>
                
                <!-- Retratos -->
                <div class="pack-category-card reveal">
                    <div class="category-icon"><i class="fas fa-user-tie"></i></div>
                    <h3>Retratos</h3>
                    <p>30 fotos con retoque avanzado incluido.</p>
                    <a href="/servicios/retratos-profesionales-valencia#tarifas" class="pack-preview-info-btn">
                        <span class="pack-name-preview">Pro Portfolio</span>
                        <span class="pack-price-preview">Desde 160€</span>
                    </a>
                </div>
                
                <!-- Eventos -->
                <div class="pack-category-card reveal">
                    <div class="category-icon"><i class="fas fa-calendar-alt"></i></div>
                    <h3>Eventos</h3>
                    <p>3 horas de cobertura y video de regalo.</p>
                    <a href="/servicios/fotografo-eventos-valencia#tarifas" class="pack-preview-info-btn">
                        <span class="pack-name-preview">Full Coverage</span>
                        <span class="pack-price-preview">Desde 180€</span>
                    </a>
                </div>
                
                <!-- Branding -->
                <div class="pack-category-card reveal">
                    <div class="category-icon"><i class="fas fa-briefcase"></i></div>
                    <h3>Branding</h3>
                    <p>Contenido visual para un mes completo.</p>
                    <a href="/servicios/fotografia-marca-personal-valencia#tarifas" class="pack-preview-info-btn">
                        <span class="pack-name-preview">Brand Story</span>
                        <span class="pack-price-preview">Desde 200€</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <style>
        .packs-categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .pack-category-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 3rem 2rem;
            text-align: center;
            transition: all 0.4s ease;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .pack-category-card:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: var(--color-gold);
            transform: translateY(-5px);
        }

        .category-icon {
            font-size: 2rem;
            color: var(--color-gold);
            margin-bottom: 1.5rem;
        }

        .pack-category-card h3 {
            font-size: 1.2rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }

        .pack-preview-info-btn {
            display: flex;
            flex-direction: column;
            gap: 5px;
            padding: 1.2rem;
            background: rgba(197, 160, 89, 0.1);
            border: 1px solid var(--color-gold);
            transition: all 0.3s ease;
            text-decoration: none;
            color: inherit;
        }

        .pack-preview-info-btn:hover {
            background: var(--color-gold);
            transform: scale(1.02);
        }

        .pack-preview-info-btn:hover .pack-name-preview,
        .pack-preview-info-btn:hover .pack-price-preview {
            color: var(--color-secondary);
        }

        .pack-name-preview {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--color-gold);
            font-weight: 700;
        }

        .pack-price-preview {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
        }

        .pack-category-card p {
            font-size: 0.85rem;
            color: var(--color-text-light);
            margin-bottom: 2rem;
            min-height: 2.5rem;
        }
    </style>

    <section id="testimonios" class="section-padding">
        <div class="container reveal" style="overflow: visible;">
            <h2 class="section-title">Testimonios</h2>
            <div class="testimonials-nav-wrapper">
                <button class="slider-nav-btn prev" id="testimonial-prev" aria-label="Anterior testimonio"
                    ><i class="fas fa-chevron-left"></i></button
                >
                <button class="slider-nav-btn next" id="testimonial-next" aria-label="Siguiente testimonio"
                    ><i class="fas fa-chevron-right"></i></button
                >
                <div class="testimonials-slider-wrapper">
                    <div class="testimonials-slider" id="testimonials-slider">
                        <div class="testimonial-item">
                            <div class="testimonial-content">
                                <div class="testimonial-img">
                                    <Image
                                        src={getImg("Modelo/2.webp") || heroImg}
                                        alt="Elena G."
                                        width={100}
                                        height={100}
                                    />
                                </div>
                                <p>
                                    "Increíbles fotos de retrato que contraté. Javier captó exactamente lo que quería."
                                </p>
                                <span class="testimonial-author">Mike A.</span>
                                <span class="testimonial-role">Deportista</span>
                            </div>
                        </div>
                        <div class="testimonial-item">
                            <div class="testimonial-content">
                                <div class="testimonial-img">
                                    <Image
                                        src={getImg("Deportes/1.webp") || heroImg}
                                        alt="Club Tenis Valencia"
                                        width={100}
                                        height={100}
                                    />
                                </div>
                                <p>
                                    "Las fotos de mi partido de tenis son espectaculares. La rapidez de entrega y la
                                    calidad me fascinó."
                                </p>
                                <span class="testimonial-author">Jorge P.</span>
                                <span class="testimonial-role">Jugador de Tenis</span>
                            </div>
                        </div>
                        <div class="testimonial-item">
                            <div class="testimonial-content">
                                <div class="testimonial-img">
                                    <Image
                                        src={getImg("Modelo/11.webp") || heroImg}
                                        alt="Marc R."
                                        width={100}
                                        height={100}
                                    />
                                </div>
                                <p>
                                    "La sesion de fotos de gimnasio de me hizo Javier fueron espectaculares y con mucha
                                    calidad."
                                </p>
                                <span class="testimonial-author">Jose Manuel</span>
                                <span class="testimonial-role">Modelo gym</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <!-- FAQ Section -->
    <section id="faq" class="section-padding" style="background: var(--color-secondary);">
        <div class="container reveal">
            <h2 class="section-title">Preguntas Frecuentes</h2>
            <div class="faq-grid" style="max-width: 800px; margin: 0 auto; margin-top: 4rem;">
                <div class="faq-item">
                    <div class="faq-question">¿Cuánto tiempo tardas en entregar las fotos? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer"><p>Normalmente entrego una selección previa en 48h y el pack completo editado en un plazo de 7 a 10 días laborables.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Te desplazas fuera de Valencia? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer"><p>¡Claro! Aunque mi base está en Valencia, puedo desplazarme a cualquier lugar. Consúltame disponibilidad y gastos de desplazamiento.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Cómo se realiza el pago? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer"><p>Para reservar la fecha se abona una señal del 25%. El resto se paga el mismo día de la sesión o al finalizar el evento.</p></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question">¿Entregas las fotos sin editar (RAW)? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer"><p>No, mi trabajo incluye el revelado y la edición artística. Selecciono y edito las mejores tomas para asegurar un resultado profesional.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA Signature -->
    <section class="section-padding signature-cta reveal">
        <div class="container text-center">
            <div class="signature-box" style="border: 1px solid rgba(197, 160, 89, 0.2); padding: 4rem 2rem; background: rgba(255,255,255,0.02); border-radius: 4px;">
                <h2 class="signature-title">Crea tu historia</h2>
                <p style="color: var(--color-text-light); margin-bottom: 2.5rem; font-size: 1.1rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                    Cada clic es una oportunidad para hacer algo eterno. Reserva tu sesión hoy y capturemos lo extraordinario.
                </p>
                <a href="/contacto" class="btn luxury-gallery-btn" style="display: inline-flex; align-items: center; justify-content: center; gap: 10px;">
                    Empezar Proyecto <i class="fas fa-star" style="font-size: 0.8rem;"></i>
                </a>
            </div>
        </div>
    </section>

    <style>
        .faq-grid {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .faq-item {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem 0;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9rem;
            color: var(--color-gold);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .faq-answer p {
            padding: 1.5rem 0;
            color: var(--color-text-light);
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .faq-item.active .faq-answer {
            max-height: 200px;
        }

        .faq-item.active i {
            transform: rotate(45deg);
            color: #fff;
        }

        .signature-cta {
            background: var(--color-secondary);
        }

        .signature-title {
            font-size: 2.5rem; 
            letter-spacing: 5px; 
            margin-bottom: 1.5rem;
            text-transform: uppercase;
        }

        @media (max-width: 768px) {
            .signature-title {
                font-size: 1.5rem;
                letter-spacing: 3px;
            }
            
            .signature-box {
                padding: 3rem 1.5rem !important;
            }
        }
    </style>

    <script>
        document.querySelectorAll('.faq-item').forEach(item => {
            item.addEventListener('click', () => {
                item.classList.toggle('active');
            });
        });
    </script>


</Layout>
