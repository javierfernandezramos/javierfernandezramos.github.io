    }

    .total-section {
        margin-top: 2rem;
        padding-top: 1.2rem;
        border-top: 2px solid var(--color-gold);
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        color: var(--color-text-light);
