        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

    .extras-list {
        margin: 1.5rem 0;
    }

    .extra-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.02);
        padding: 1rem;
        margin-bottom: 0.8rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .extra-name {
        font-weight: 600;
        font-size: 0.85rem;
    }

    .extra-price {
        font-size: 0.75rem;
        color: var(--color-gold);
    }

    .counter {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100px;
    }

    .counter button {
        background: transparent;
        border: 1px solid var(--color-gold);
        color: var(--color-gold);
        width: 26px;
        height: 26px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
    }

    .counter input::-webkit-outer-spin-button,
    .counter input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .counter input[type=number] {
        -moz-appearance: textfield;
    }

    .counter input {
        background: transparent;
        border: none;
        color: #fff;
        width: 30px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
