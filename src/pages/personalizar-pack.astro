---
import Layout from '../layouts/Layout.astro';
import { servicesPacks } from '../data/packs';
---

<Layout 
    title="Personalizar Pack - JaviPhoto"
    description="Personaliza tu pack de fotografía con extras y calcula el presupuesto final."
    noIndex={true}
>
    <section class="section-padding custom-pack-section">
        <div class="container reveal">
            <h1 class="section-title">Personaliza tu Pack</h1>
            
            <div id="calculator-loading" class="text-center loading-container">
                <div class="spinner central-spinner"></div>
                <p>Cargando detalles del pack...</p>
            </div>

            <!-- Selector de Packs si se accede directamente -->
            <div id="pack-selector-container" class="pack-selector-wrapper hidden">
                <p class="selector-description">Selecciona un tipo de servicio</p>
                
                <!-- Desplegable Personalizado -->
                <div class="custom-dropdown-container">
                    <button class="dropdown-trigger" id="dropdown-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
                        <span id="dropdown-selected-text">Selecciona un servicio...</span>
                        <i class="fas fa-chevron-down arrow-icon"></i>
                    </button>
                    <ul class="dropdown-menu hidden" id="dropdown-menu" role="listbox">
                        <!-- Inyección dinámica de los ítems -->
                    </ul>
                </div>
                
                <div id="packs-selector-subgrid-container" class="packs-selector-subgrid-container hidden">
                    <h3 class="selector-subtitle text-center">Selecciona un Pack para personalizar</h3>
                    <div class="packs-selector-grid" id="packs-selector-grid">
                        <!-- Inyección dinámica -->
                    </div>
                </div>
            </div>

            <div id="calculator-content" class="calculator-wrapper hidden">
                <div class="calculator-grid">
                    <!-- Columna Izquierda: Detalle -->
                    <div class="calculator-sidebar-col">
                        <div class="calculator-card pack-info">
                            <div class="card-tag">Pack Seleccionado</div>
                            <h2 id="ui-pack-name">Cargando...</h2>
                            <div id="ui-service-title" class="pack-service">Cargando...</div>
                            
                            <ul id="ui-features-list" class="calculator-features">
                                <!-- Features will be injected here -->
                            </ul>
                            
                            <div id="ui-bonus-box" class="calculator-bonus hidden">
                                <i class="fas fa-gift"></i> <span id="ui-bonus-text"></span>
                            </div>
                            
                            <div class="base-price">Precio Base: <span id="ui-base-price">0€</span></div>
                        </div>

                        <div class="calculator-actions-sidebar">
                            <a id="btn-volver" href="/servicios" class="btn btn-outline-luxury sidebar-back-btn">
                                <i class="fas fa-arrow-left"></i> Elegir otro pack
                            </a>
                        </div>
                    </div>

                    <!-- Columna Derecha: Calculadora -->
                    <div class="calculator-card pricing-calculator">
                        <h3>Añade Extras</h3>
                        <p class="small-text">Personaliza tu sesión añadiendo más cantidad de fotos editadas.</p>
                        
                        <div class="extras-list">
                            <div class="extra-item">
                                <div class="extra-info">
                                    <span class="extra-name">Foto Extra Editada</span>
                                    <span class="extra-price">+5€ / unidad</span>
                                </div>
                                <div class="counter">
                                    <button type="button" id="minus-one" aria-label="Menos uno"><i class="fas fa-minus"></i></button>
                                    <input type="number" id="extra-photos" value="0" min="0" readonly />
                                    <button type="button" id="plus-one" aria-label="Más uno"><i class="fas fa-plus"></i></button>
                                </div>
                            </div>

                            <div class="extra-item">
                                <div class="extra-info">
                                    <span class="extra-name">Pack 10 Fotos Extra Editadas</span>
                                    <span class="extra-price">+35€</span>
                                </div>
                                <div class="counter">
                                    <button type="button" id="minus-pack" aria-label="Menos un pack"><i class="fas fa-minus"></i></button>
                                    <input type="number" id="extra-packs" value="0" min="0" readonly />
                                    <button type="button" id="plus-pack" aria-label="Más un pack"><i class="fas fa-plus"></i></button>
                                </div>
                            </div>
                        </div>

                        <div class="calculator-contact-fields">
                            <h3>Tus Datos de Contacto</h3>
                            <div class="input-group">
                                <label for="user-name">Nombre Completo</label>
                                <div class="input-relative">
                                    <i class="fas fa-user"></i>
                                    <input type="text" id="user-name" placeholder="Tu nombre..." required />
                                </div>
                            </div>
                            <div class="input-group">
                                <label for="user-email">Correo Electrónico</label>
                                <div class="input-relative">
                                    <i class="fas fa-envelope"></i>
                                    <input type="email" id="user-email" placeholder="tu@email.com..." required />
                                </div>
                            </div>
                            <div class="input-group">
                                <label for="user-phone">Teléfono</label>
                                <div class="input-relative">
                                    <i class="fas fa-phone"></i>
                                    <input type="tel" id="user-phone" placeholder="600 000 000..." required />
                                </div>
                            </div>
                        </div>

                        <div class="total-section">
                            <div class="total-row">
                                <span>Base:</span>
                                <span id="ui-summary-base">0€</span>
                            </div>
                            <div class="total-row">
                                <span>Extras:</span>
                                <span id="extras-total">0€</span>
                            </div>
                            <div class="total-row grand-total">
                                <span>Presupuesto Estimado:</span>
                                <span id="grand-total">0€</span>
                            </div>
                        </div>

                        <button id="btn-finalizar" class="btn submit-btn finalize-btn">
                            Finalizar y Enviar Mensaje <i class="fas fa-paper-plane"></i>
                        </button>
                        <p id="error-msg" class="small-note text-center error-status hidden">
                            Por favor, rellena todos los campos de contacto.
                        </p>
                        <p class="small-note text-center footer-note">
                            El mensaje se enviará directamente a JaviPhoto y recibirás una respuesta en tu correo.
                        </p>
                    </div>
                </div>
            </div>

            <div id="calculator-error" class="text-center error-container hidden">
                <i class="fas fa-exclamation-circle error-icon"></i>
                <h2>No se pudo encontrar el pack</h2>
                <p>Por favor, vuelve a la página de servicios y selecciona un pack válido.</p>
                <a href="/servicios" class="btn error-back-btn">Ver Servicios</a>
            </div>
            
            </div>
        </div>
    </section>
</Layout>

<script define:vars={{ allPacks: servicesPacks }}>
    const slugMap = {
        deportes: '/servicios/fotografo-deportivo-valencia',
        eventos: '/servicios/fotografo-eventos-valencia',
        retratos: '/servicios/retratos-profesionales-valencia',
        branding: '/servicios/fotografia-marca-personal-valencia'
    };
    const serviceIcons = {
        deportes: 'fas fa-running',
        retratos: 'fas fa-user-alt',
        eventos: 'fas fa-calendar-check',
        branding: 'fas fa-briefcase',
        fitness: 'fas fa-dumbbell'
    };

    // Get Elements
    const loadingEl = document.getElementById('calculator-loading');
    const contentEl = document.getElementById('calculator-content');
    const errorEl = document.getElementById('calculator-error');
    const selectorEl = document.getElementById('pack-selector-container');

    const uiPackName = document.getElementById('ui-pack-name');
    const uiServiceTitle = document.getElementById('ui-service-title');
    const uiFeaturesList = document.getElementById('ui-features-list');
    const uiBonusBox = document.getElementById('ui-bonus-box');
    const uiBonusText = document.getElementById('ui-bonus-text');
    const uiBasePrice = document.getElementById('ui-base-price');
    const uiSummaryBase = document.getElementById('ui-summary-base');

    const photosInput = document.getElementById('extra-photos');
    const packsInput = document.getElementById('extra-packs');
    const extrasTotalEl = document.getElementById('extras-total');
    const grandTotalEl = document.getElementById('grand-total');
    const btnFinalizar = document.getElementById('btn-finalizar');
    const btnVolver = document.getElementById('btn-volver');
    const dropdownMenu = document.getElementById('dropdown-menu');
    const dropdownContainer = document.querySelector('.custom-dropdown-container');

    // State
    let currentService = null;
    let currentPack = null;
    let basePrice = 0;
    let extraPhotos = 0;
    let extraPacks = 0;
    let directEntry = false;

    // Parse URL Params
    const urlParams = new URLSearchParams(window.location.search);
    const serviceId = urlParams.get('service');
    const packId = urlParams.get('pack');

    const service = allPacks[serviceId];
    const pack = service ? service.packs.find(p => p.id === packId) : null;

    if (serviceId && packId && pack) {
        directEntry = false;
        loadPackIntoCalculator(serviceId, packId);
    } else {
        directEntry = true;
        showSelector();
    }

    // Manejador del click para abrir/cerrar y cerrar al hacer clic fuera del desplegable
    document.addEventListener('click', (e) => {
        const trigger = document.getElementById('dropdown-trigger');
        if (!trigger || !dropdownMenu || !dropdownContainer) return;

        if (trigger.contains(e.target)) {
            const isOpen = dropdownContainer.classList.contains('open');
            if (isOpen) {
                dropdownContainer.classList.remove('open');
                dropdownMenu.classList.add('hidden');
            } else {
                dropdownContainer.classList.add('open');
                dropdownMenu.classList.remove('hidden');
            }
        } else if (!dropdownContainer.contains(e.target)) {
            dropdownContainer.classList.remove('open');
            dropdownMenu.classList.add('hidden');
        }
    });

    function selectDropdownItem(sKey, itemEl, preventScroll = false) {
        if (!dropdownContainer || !dropdownMenu) return;
        
        document.querySelectorAll('.dropdown-item').forEach(el => el.classList.remove('selected'));
        itemEl.classList.add('selected');

        const s = allPacks[sKey];
        const iconClass = serviceIcons[sKey] || 'fas fa-camera';
        
        const triggerText = document.getElementById('dropdown-selected-text');
        if (triggerText) {
            triggerText.innerHTML = `<span style="display: flex; align-items: center; gap: 10px;"><i class="${iconClass}" style="color: var(--color-gold);"></i> ${s.title}</span>`;
        }
        
        dropdownContainer.classList.remove('open');
        dropdownMenu.classList.add('hidden');

        showPacksForService(sKey, preventScroll);
    }

    function showSelector() {
        loadingEl.classList.add('hidden');
        contentEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        selectorEl.classList.remove('hidden');

        dropdownMenu.innerHTML = '';

        const keys = Object.keys(allPacks);

        keys.forEach(sKey => {
            const s = allPacks[sKey];
            const li = document.createElement('li');
            li.className = 'dropdown-item';
            li.setAttribute('data-id', sKey);
            li.setAttribute('role', 'option');
            
            const iconClass = serviceIcons[sKey] || 'fas fa-camera';
            li.innerHTML = `
                <span>${s.title}</span>
                <i class="${iconClass}"></i>
            `;

            li.addEventListener('click', (e) => {
                e.stopPropagation();
                selectDropdownItem(sKey, li);
            });

            dropdownMenu.appendChild(li);
        });

        // Seleccionar por defecto el primero
        if (keys.length > 0) {
            const firstItem = dropdownMenu.querySelector(`[data-id="${keys[0]}"]`);
            if (firstItem) {
                selectDropdownItem(keys[0], firstItem, true);
            }
        }
    }

    function showPacksForService(sId, preventScroll = false) {
        const subgridContainer = document.getElementById('packs-selector-subgrid-container');
        const packsGrid = document.getElementById('packs-selector-grid');
        
        packsGrid.innerHTML = '';
        const serviceData = allPacks[sId];
        if (!serviceData) return;

        serviceData.packs.forEach(p => {
            const pCard = document.createElement('div');
            pCard.className = 'pack-select-card';
            
            let badgeHTML = p.isPopular ? `<span class="pack-badge">Popular</span>` : '';
            let priceText = p.priceLabel ? p.priceLabel : `${p.price}€`;
            
            pCard.innerHTML = `
                ${badgeHTML}
                <div>
                    <h4>${p.name}</h4>
                    <div class="pack-price">${priceText}</div>
                    <p>${p.description}</p>
                </div>
                <button class="pack-select-btn">Personalizar Pack</button>
            `;

            pCard.addEventListener('click', () => {
                loadPackIntoCalculator(sId, p.id);
            });

            packsGrid.appendChild(pCard);
        });

        subgridContainer.classList.remove('hidden');
        if (!preventScroll) {
            subgridContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    }

    function loadPackIntoCalculator(sId, pId) {
        currentService = allPacks[sId];
        currentPack = currentService ? currentService.packs.find(p => p.id === pId) : null;

        if (!currentPack) {
            showSelector();
            return;
        }

        // Reset
        extraPhotos = 0;
        extraPacks = 0;
        photosInput.value = '0';
        packsInput.value = '0';

        // Populate UI
        basePrice = currentPack.price;
        uiPackName.textContent = currentPack.name;
        uiServiceTitle.textContent = currentService.title;
        uiBasePrice.textContent = `${currentPack.price}€`;
        uiSummaryBase.textContent = `${currentPack.price}€`;
        grandTotalEl.textContent = `${currentPack.price}€`;

        // Features
        uiFeaturesList.innerHTML = '';
        currentPack.features.forEach(feature => {
            const li = document.createElement('li');
            li.innerHTML = `<i class="fas fa-check"></i> ${feature}`;
            uiFeaturesList.appendChild(li);
        });

        // Bonus
        if (currentPack.bonus) {
            uiBonusBox.style.display = 'block';
            uiBonusText.textContent = currentPack.bonus;
        } else {
            uiBonusBox.style.display = 'none';
        }

        // Set back button link
        if (sId && slugMap[sId]) {
            btnVolver.href = slugMap[sId];
        } else {
            btnVolver.href = '/servicios';
        }

        updateTotals();

        // Show Content
        loadingEl.classList.add('hidden');
        selectorEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        contentEl.classList.remove('hidden');

        // Update URL query parameters dynamically
        const newUrl = `${window.location.pathname}?service=${sId}&pack=${pId}`;
        window.history.pushState({ service: sId, pack: pId }, '', newUrl);
    }

    function updateTotals() {
        const extrasTotal = (extraPhotos * 5) + (extraPacks * 35);
        const grandTotal = basePrice + extrasTotal;

        extrasTotalEl.textContent = `${extrasTotal}€`;
        grandTotalEl.textContent = `${grandTotal}€`;
    }

    // Event Listeners for Photos
    document.getElementById('plus-one')?.addEventListener('click', () => {
        extraPhotos++;
        photosInput.value = extraPhotos;
        updateTotals();
    });
    document.getElementById('minus-one')?.addEventListener('click', () => {
        if (extraPhotos > 0) {
            extraPhotos--;
            photosInput.value = extraPhotos;
            updateTotals();
        }
    });

    // Event Listeners for Packs
    document.getElementById('plus-pack')?.addEventListener('click', () => {
        extraPacks++;
        packsInput.value = extraPacks;
        updateTotals();
    });
    document.getElementById('minus-pack')?.addEventListener('click', () => {
        if (extraPacks > 0) {
            extraPacks--;
            packsInput.value = extraPacks;
            updateTotals();
        }
    });

    // Set back button link
    btnVolver?.addEventListener('click', (e) => {
        if (directEntry) {
            e.preventDefault();
            contentEl.classList.add('hidden');
            selectorEl.classList.remove('hidden');
            // Remove params from URL
            window.history.pushState({}, '', window.location.pathname);
            // Reset active classes
            document.querySelectorAll('.dropdown-item').forEach(c => c.classList.remove('selected'));
            document.getElementById('packs-selector-subgrid-container').classList.add('hidden');
            
            const triggerText = document.getElementById('dropdown-selected-text');
            if (triggerText) {
                triggerText.textContent = 'Selecciona un servicio...';
            }

            // Open the dropdown menu automatically for convenience
            dropdownContainer.classList.add('open');
            dropdownMenu.classList.remove('hidden');
        }
    });

    // Handle Finalize
    btnFinalizar?.addEventListener('click', async () => {
        const name = document.getElementById('user-name').value;
        const email = document.getElementById('user-email').value;
        const phone = document.getElementById('user-phone').value;
        const errorMsg = document.getElementById('error-msg');

        if (!name || !email || !phone) {
            errorMsg.classList.remove('hidden');
            return;
        }

        errorMsg.style.display = 'none';
        btnFinalizar.disabled = true;
        btnFinalizar.innerHTML = 'Enviando... <i class="fas fa-spinner fa-spin"></i>';

        const total = basePrice + (extraPhotos * 5) + (extraPacks * 35);
        
        // Prepare data for Formspree
        const formData = new FormData();
        formData.append('_subject', `Nueva Reserva: ${currentPack.name} - ${currentService.title}`);
        formData.append('pack_name', currentPack.name);
        formData.append('servicio', currentService.title);
        formData.append('precio_base', `${basePrice}€`);
        formData.append('fotos_extra', extraPhotos.toString());
        formData.append('packs_extra', extraPacks.toString());
        formData.append('total_estimado', `${total}€`);
        formData.append('cliente_nombre', name);
        formData.append('cliente_email', email);
        formData.append('cliente_telefono', phone);
        formData.append('mensaje', `Reserva solicitada desde la calculadora web.`);

        try {
            const response = await fetch("https://formspree.io/f/xkoyqbdj", {
                method: "POST",
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                btnFinalizar.innerHTML = '¡Enviado con éxito! <i class="fas fa-check"></i>';
                btnFinalizar.style.backgroundColor = '#28a745';
                btnFinalizar.style.borderColor = '#28a745';
                setTimeout(() => {
                    window.location.href = "/";
                }, 2000);
            } else {
                throw new Error();
            }
        } catch (error) {
            console.error("Error en Formspree:", error);
            btnFinalizar.disabled = false;
            btnFinalizar.innerHTML = 'Error al enviar. Reintentar <i class="fas fa-exclamation-triangle"></i>';
            alert("Hubo un error al enviar el formulario directamente. Por favor, asegúrate de haber activado tu formulario en Formspree o usa un ID de formulario válido.");
        }
    });
</script>

<style>
    .custom-pack-section {
        padding-top: 10rem !important;
        min-height: 100vh;
    }

    .loading-container {
        padding: 5rem 0;
    }

    .central-spinner {
        margin: 0 auto 1rem;
    }

    .hidden {
        display: none !important;
    }

    .sidebar-back-btn {
        width: 100%;
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

    .input-relative {
        position: relative;
    }

    .finalize-btn {
        width: 100%;
        margin-top: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .error-status {
        margin-top: 1rem;
        color: #ff6b6b;
    }

    .footer-note {
        margin-top: 1rem;
        opacity: 0.6;
    }

    .error-container {
        padding: 5rem 0;
    }

    .error-icon {
        font-size: 3rem;
        color: var(--color-gold);
        margin-bottom: 1rem;
    }

    .error-back-btn {
        margin-top: 2rem;
    }

    .calculator-contact-fields {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
    }

    .calculator-contact-fields h3 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 1.5rem;
        color: var(--color-gold);
        text-align: center;
    }

    .input-group {
        margin-bottom: 1rem;
        position: relative;
    }

    .input-group label {
        display: block;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        color: var(--color-text-light);
    }

    .input-group i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-gold);
        font-size: 0.8rem;
        opacity: 0.6;
        pointer-events: none;
    }

    .input-group input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.8rem 1rem 0.8rem 2.8rem;
        color: #fff;
        border-radius: 6px;
        font-size: 0.9rem;
    }

    .calculator-wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }

    .calculator-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 2rem;
        align-items: start;
    }

    @media (max-width: 850px) {
        .calculator-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        
        .calculator-card {
            padding: 1.5rem !important;
        }
        
        .section-padding {
            padding: 7rem 0 4rem !important;
        }

        .pack-info h2 {
            font-size: 1.5rem !important;
        }
    }

    .btn-outline-luxury {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--color-text-light);
        padding: 1rem 1.5rem;
        font-size: 0.8rem;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-weight: 700;
        width: 100%;
    }

    .btn-outline-luxury:hover {
        border-color: var(--color-gold);
        color: var(--color-gold);
        background: rgba(197, 160, 89, 0.05);
    }

    .calculator-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 2.5rem;
        backdrop-filter: blur(10px);
        position: relative;
    }

    .card-tag {
        display: inline-block;
        background: var(--color-gold);
        color: var(--color-secondary);
        padding: 0.2rem 0.6rem;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .pack-info h2 {
        font-size: 1.8rem;
        margin-bottom: 0.5rem;
        letter-spacing: 1px;
    }

    .pack-service {
        color: var(--color-gold);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .calculator-features {
        list-style: none;
        padding: 0;
        margin-bottom: 1.5rem;
    }

    .calculator-features li {
        margin-bottom: 0.8rem;
        font-size: 0.85rem;
        display: flex;
        gap: 10px;
        color: var(--color-text-light);
    }

    .calculator-features i {
        color: var(--color-gold);
        font-size: 0.8rem;
    }

    .calculator-bonus {
        background: rgba(197, 160, 89, 0.08);
        border: 1px dashed var(--color-gold);
        padding: 0.8rem;
        color: var(--color-gold);
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

    .base-price {
        font-size: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding-top: 1rem;
    }

    .base-price span {
        font-weight: 700;
        color: #fff;
    }

    .pricing-calculator h3 {
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

